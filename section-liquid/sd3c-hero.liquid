<style>
  :root {
    --verde: #7a9d8e;
    --verde-claro: #9dbcb3;
    --verde-fondo: #eaf4f0;
    --rosa: #d8a7b1;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --fondo: #f1ebe5;
    --radio: 14px;
    --sombra: 0 4px 24px rgba(122,157,142,.12);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--fondo); color: var(--gris-oscuro); line-height: 1.65; }
  img { max-width: 100%; display: block; }
  .sd3c-container { max-width: 780px; margin: 0 auto; padding: 0 20px; }
  .sd3c-tag {
    display: inline-block;
    background: var(--verde-fondo);
    color: var(--verde);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 99px;
    margin-bottom: 16px;
  }
  .sd3c-hero {
    background: var(--verde-fondo);
    color: var(--gris-oscuro);
    padding: 80px 20px 72px;
    text-align: center;
  }
  .sd3c-hero h1 {
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 800;
    max-width: 720px;
    margin: 0 auto 24px;
    line-height: 1.25;
  }
  .sd3c-hero h1 em { font-style: normal; color: var(--verde); }
  .sd3c-subtitulo {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--gris-medio);
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .sd3c-badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 40px;
  }
  .sd3c-badge {
    background: #fff;
    border: 1px solid var(--verde-claro);
    border-radius: 99px;
    padding: 7px 18px;
    font-size: 14px;
    font-weight: 600;
    color: var(--gris-oscuro);
  }
  .sd3c-btn-cta {
    display: inline-block;
    background: var(--rosa);
    color: var(--gris-oscuro);
    font-size: 18px;
    font-weight: 800;
    padding: 18px 40px;
    border-radius: 99px;
    box-shadow: 0 8px 32px rgba(216,167,177,.45);
    cursor: pointer;
    transition: transform .15s, box-shadow .15s;
    border: none;
    text-align: center;
    text-decoration: none;
  }
  .sd3c-btn-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(216,167,177,.55); }
  .sd3c-btn-cta.grande {
    font-size: 20px;
    padding: 22px 52px;
    animation: sd3cCtaPulse 2.4s ease-in-out infinite;
  }
  .sd3c-btn-cta.grande:hover { animation: none; transform: translateY(-3px); }
  @keyframes sd3cCtaPulse {
    0%,100% { box-shadow: 0 8px 32px rgba(216,167,177,.45); }
    50%     { box-shadow: 0 8px 48px rgba(216,167,177,.75), 0 0 0 6px rgba(216,167,177,.15); }
  }
  @keyframes sd3cHeroFadeUp { from { opacity:0; transform:translateY(32px); } to { opacity:1; transform:translateY(0); } }
  .sd3c-hero .sd3c-tag       { animation: sd3cHeroFadeUp .5s ease .1s both; }
  .sd3c-hero h1              { animation: sd3cHeroFadeUp .5s ease .22s both; }
  .sd3c-hero .sd3c-subtitulo { animation: sd3cHeroFadeUp .5s ease .34s both; }
  .sd3c-hero .sd3c-badge-row { animation: sd3cHeroFadeUp .5s ease .44s both; }
  .sd3c-hero .sd3c-btn-cta   { animation: sd3cHeroFadeUp .5s ease .54s both; }
  .sd3c-hero .sd3c-trust-bar { animation: sd3cHeroFadeUp .5s ease .64s both; }
  .sd3c-trust-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 20px;
    margin-top: 18px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gris-medio);
  }
  .sd3c-trust-bar span { display: inline-flex; align-items: center; gap: 6px; }
  .sd3c-trust-bar i { color: var(--verde); font-size: 12px; }
</style>

{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css' | stylesheet_tag }}

<section class="sd3c-hero">
  <div class="sd3c-container">
    <div class="sd3c-tag">{{ section.settings.tag }}</div>
    <h1>{{ section.settings.headline }}</h1>
    <p class="sd3c-subtitulo">{{ section.settings.subtitle }}</p>
    <div class="sd3c-badge-row">
      <span class="sd3c-badge">⏱ 5 min · 10 min · 20 min</span>
      <span class="sd3c-badge">🧠 Sin agotamiento mental</span>
      <span class="sd3c-badge">🌿 Sin hinchazón</span>
      <span class="sd3c-badge">📱 App incluida</span>
    </div>
    <a href="{% if section.settings.open_upsell %}#upsell-modal{% else %}{{ section.settings.cta_url }}{% endif %}" class="sd3c-btn-cta grande">{{ section.settings.cta_text }}</a>
    <div class="sd3c-trust-bar">
      <span><i class="fa-solid fa-lock"></i> Compra segura</span>
      <span><i class="fa-solid fa-bolt"></i> Acceso inmediato</span>
      <span><i class="fa-solid fa-shield-halved"></i> Garantía 7 días sin preguntas</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD3C Hero",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta (tag)",
      "default": "Sistema Digestivo · Vida en Calma"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Título principal (H1)",
      "default": "Deja de pensar \"no tengo tiempo para comer bien\" y empieza a comer sin hinchazón ni estrés con 500 recetas listas en 5, 10 o 20 minutos según tu día."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Come mejor sin pensar: accede a 500 recetas organizadas por tiempo, momento y necesidad, y olvídate para siempre del estrés diario de decidir qué cocinar."
    },
    {
      "type": "checkbox",
      "id": "open_upsell",
      "label": "Abrir modal de upsell al hacer clic",
      "default": false
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón CTA (cuando no se usa el modal)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón CTA",
      "default": "👉 Quiero empezar hoy"
    }
  ],
  "presets": [
    {
      "name": "SD3C Hero"
    }
  ]
}
{% endschema %}
