<style>
  :root {
    --verde: #7a9d8e;
    --verde-claro: #9dbcb3;
    --verde-fondo: #eaf4f0;
    --rosa: #d8a7b1;
    --rojo: #c4757f;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --blanco: #FFFFFF;
    --fondo: #f1ebe5;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; }
  .sd3c-pricing-section { background: var(--fondo); padding: 44px 20px; border-top: 1px solid #d4c4bc; }
  @keyframes sd3cPricingDrop { from { opacity:0; transform:scale(.96) translateY(16px); } to { opacity:1; transform:scale(1) translateY(0); } }
  .sd3c-pricing-box { max-width: 480px; margin: 0 auto; text-align: center; animation: sd3cPricingDrop .55s ease .1s both; }
  .sd3c-pricing-stars { color: #f5a623; font-size: 19px; margin-bottom: 4px; }
  .sd3c-pricing-reviews { font-size: 14px; color: #777; margin-bottom: 22px; }
  .sd3c-pricing-main { font-weight: 900; font-size: 40px; color: #111; line-height: 1; margin-bottom: 6px; }
  .sd3c-pricing-old { font-size: 16px; color: #aaa; text-decoration: line-through; margin-bottom: 16px; }
  .sd3c-pricing-savings-btn {
    display: inline-block; background: linear-gradient(135deg, #9dbcb3, #7a9d8e);
    color: var(--blanco); font-weight: 800; font-size: 16px; padding: 13px 28px;
    border-radius: 30px; margin-bottom: 10px;
    box-shadow: 0 4px 14px rgba(122,157,142,.45);
    text-decoration: none; cursor: pointer; transition: transform .18s, box-shadow .18s;
  }
  .sd3c-pricing-savings-btn:hover { transform: scale(1.06) translateY(-2px); }
  .sd3c-pricing-countdown {
    background: var(--verde-fondo); border: 2px solid var(--verde-claro);
    border-radius: 12px; padding: 16px 18px; margin: 14px 0; text-align: center;
  }
  .sd3c-pc-header { font-size: 14px; font-weight: 700; color: var(--verde); margin-bottom: 10px; }
  .sd3c-pc-digits { display: flex; justify-content: center; gap: 6px; align-items: flex-end; margin-bottom: 10px; }
  .sd3c-pc-unit { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .sd3c-pc-num {
    background: var(--verde); color: var(--blanco); font-size: 29px;
    font-weight: 900; padding: 6px 14px; border-radius: 8px; min-width: 52px; line-height: 1;
  }
  .sd3c-pc-lbl { font-size: 11px; font-weight: 700; color: var(--rosa); text-transform: uppercase; letter-spacing: .5px; }
  .sd3c-pc-sep { font-size: 29px; font-weight: 900; color: var(--rosa); line-height: 1; padding-bottom: 6px; }
  .sd3c-pc-footer { font-size: 12px; color: #888; }
  .sd3c-pricing-offer-btn {
    display: block; background: var(--rosa); color: var(--gris-oscuro);
    font-weight: 800; font-size: 17px; padding: 15px; border-radius: 10px;
    text-decoration: none; margin-bottom: 24px; cursor: pointer;
    transition: transform .18s, box-shadow .18s;
    box-shadow: 0 8px 0 #c4a0aa, 0 12px 24px rgba(216,167,177,.4);
  }
  .sd3c-pricing-offer-btn:hover { transform: translateY(3px); box-shadow: 0 5px 0 #c4a0aa, 0 8px 18px rgba(216,167,177,.3); }
  .sd3c-pricing-trust-list { list-style: none; text-align: left; display: inline-block; margin-bottom: 22px; }
  .sd3c-pricing-trust-list li { font-size: 14px; color: #444; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .sd3c-pricing-live { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 14px; font-weight: 700; color: #333; margin-bottom: 10px; }
  .sd3c-pricing-live-dot { width: 10px; height: 10px; border-radius: 50%; background: #3483fa; flex-shrink: 0; animation: sd3cBlink 1.4s infinite; }
  .sd3c-pricing-urgency { font-weight: 800; font-size: 14px; color: var(--rojo); text-transform: uppercase; letter-spacing: .5px; }
  @keyframes sd3cBlink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
</style>

{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css' | stylesheet_tag }}

<section class="sd3c-pricing-section">
  <div class="sd3c-pricing-box">
    <div class="sd3c-pricing-stars">★★★★★</div>
    <div class="sd3c-pricing-reviews"><strong>4.9/5</strong> — basado en compradores verificadas</div>

    <div class="sd3c-pricing-main">{{ section.settings.price_new }}</div>
    <div class="sd3c-pricing-old">{{ section.settings.price_old }}</div>
    <a href="{% if section.settings.open_upsell %}#upsell-modal{% else %}{{ section.settings.cta_url }}{% endif %}" class="sd3c-pricing-savings-btn">{{ section.settings.savings_text }}</a>

    <div class="sd3c-pricing-countdown">
      <div style="font-size:14px;color:#555;margin-bottom:10px;line-height:1.5;">Tu lugar solo está reservado por <strong>15 minutos</strong>,<br>en caso de no acceder se cederá a otra persona.</div>
      <div class="sd3c-pc-header">{{ section.settings.countdown_header }}</div>
      <div class="sd3c-pc-digits">
        <div class="sd3c-pc-unit">
          <span class="sd3c-pc-num" id="sd3c-h">15</span>
          <span class="sd3c-pc-lbl">horas</span>
        </div>
        <span class="sd3c-pc-sep">:</span>
        <div class="sd3c-pc-unit">
          <span class="sd3c-pc-num" id="sd3c-m">00</span>
          <span class="sd3c-pc-lbl">minutos</span>
        </div>
        <span class="sd3c-pc-sep">:</span>
        <div class="sd3c-pc-unit">
          <span class="sd3c-pc-num" id="sd3c-s">00</span>
          <span class="sd3c-pc-lbl">segundos</span>
        </div>
      </div>
      <div class="sd3c-pc-footer">Cuando el contador llegue a cero, el precio vuelve al valor original.</div>
    </div>

    <a href="{% if section.settings.open_upsell %}#upsell-modal{% else %}{{ section.settings.cta_url }}{% endif %}" class="sd3c-pricing-offer-btn">{{ section.settings.cta_text }}</a>

    <ul class="sd3c-pricing-trust-list">
      <li><i class="fa-solid fa-bolt"></i> Acceso inmediato por mail</li>
      <li><i class="fa-solid fa-lock"></i> Pago seguro mediante Mercado Pago</li>
      <li><i class="fa-solid fa-shield-halved"></i> Garantía de 7 días sin preguntas</li>
    </ul>

    <div class="sd3c-pricing-live">
      <div class="sd3c-pricing-live-dot"></div>
      <span><span id="sd3c-live-count">11</span> personas viendo esto ahora</span>
    </div>
    <div class="sd3c-pricing-urgency">🔥 Precio especial por tiempo limitado — se termina hoy</div>
  </div>
</section>

<script>
(function () {
  /* Countdown */
  var KEY = 'vc_sd3c_countdown_v1';
  var end = +sessionStorage.getItem(KEY);
  if (!end || end < Date.now()) {
    end = Date.now() + (15 * 60) * 1000;
    sessionStorage.setItem(KEY, end);
  }
  function tick() {
    var diff = Math.max(0, end - Date.now());
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var eh = document.getElementById('sd3c-h');
    var em = document.getElementById('sd3c-m');
    var es = document.getElementById('sd3c-s');
    if (eh) eh.textContent = String(h).padStart(2, '0');
    if (em) em.textContent = String(m).padStart(2, '0');
    if (es) es.textContent = String(s).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);

  /* Live viewers */
  var pool = [7, 8, 9, 11, 12, 14, 16, 19];
  var liveEl = document.getElementById('sd3c-live-count');
  if (liveEl) {
    liveEl.textContent = pool[Math.floor(Math.random() * pool.length)];
    setInterval(function () { liveEl.textContent = pool[Math.floor(Math.random() * pool.length)]; }, 4500);
  }
})();
</script>

{% schema %}
{
  "name": "SD3C Pricing",
  "settings": [
    {
      "type": "text",
      "id": "price_new",
      "label": "Precio actual",
      "default": "$14.999"
    },
    {
      "type": "text",
      "id": "price_old",
      "label": "Precio tachado",
      "default": "$29.999"
    },
    {
      "type": "text",
      "id": "savings_text",
      "label": "Texto botón ahorro",
      "default": "🌿 AHORRÁS $15.000 — 50% OFF"
    },
    {
      "type": "text",
      "id": "countdown_header",
      "label": "Texto contador",
      "default": "⏰ Precio especial solo por HOY — Últimas horas con 50% OFF"
    },
    {
      "type": "checkbox",
      "id": "open_upsell",
      "label": "Abrir modal de upsell al hacer clic",
      "default": false
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón comprar (cuando no se usa el modal)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto botón oferta",
      "default": "👉 ¡QUIERO EMPEZAR HOY SIN PENSAR!"
    }
  ],
  "presets": [
    {
      "name": "SD3C Pricing"
    }
  ]
}
{% endschema %}
