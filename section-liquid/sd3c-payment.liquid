<style>
  :root {
    --verde: #7a9d8e;
    --verde-fondo: #eaf4f0;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --blanco: #FFFFFF;
    --fondo: #f1ebe5;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; }

  .sd3c-payment-section { background: #FFFFFF; }
  .sd3c-payment-container { max-width: 780px; margin: 0 auto; padding: 0 20px; }
  .sd3c-ml-block { padding: 44px 20px 24px; border-bottom: 1px solid #d4c4bc; }
  .sd3c-ml-img { max-width: 280px; height: auto; display: block; margin: 0 auto; }
  .sd3c-metodos-block { padding: 24px 20px 44px; }
  .sd3c-metodos-heading { font-size: 18px; font-weight: 800; color: var(--gris-oscuro); margin-bottom: 16px; }
  .sd3c-metodos-img { max-width: 480px; width: 100%; height: auto; display: block; }
  .sd3c-ssl-badge { display: inline-block; margin-top: 16px; font-size: 13px; color: var(--gris-medio); background: var(--verde-fondo); border: 1px solid #c0ddd5; border-radius: 99px; padding: 5px 14px; }
</style>

<section class="sd3c-payment-section">
  <div class="sd3c-payment-container">
    <div class="sd3c-ml-block" style="text-align:center;">
      {% if section.settings.img_ml != blank %}
        <img class="sd3c-ml-img" src="{{ section.settings.img_ml | img_url: 'master' }}" alt="MercadoLíder Platinum">
      {% endif %}
    </div>
    <div class="sd3c-metodos-block">
      <h3 class="sd3c-metodos-heading">Métodos de pago</h3>
      {% if section.settings.img_pagos != blank %}
        <img class="sd3c-metodos-img" src="{{ section.settings.img_pagos | img_url: 'master' }}" alt="Métodos de pago: Mercado Pago, Visa, Mastercard">
      {% endif %}
      <div><span class="sd3c-ssl-badge">🔒 Sitio protegido con SSL — Tus datos nunca se comparten con terceros</span></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD3C Pago",
  "settings": [
    {
      "type": "image_picker",
      "id": "img_ml",
      "label": "Logo MercadoLíder"
    },
    {
      "type": "image_picker",
      "id": "img_pagos",
      "label": "Imagen métodos de pago"
    }
  ],
  "presets": [
    {
      "name": "SD3C Pago"
    }
  ]
}
{% endschema %}
