<style>
  :root { --red: #d8a7b1; --red-dark: #b8879a; --dark: #2c1f1b; --text: #4a3a32; --yellow: #ffd60a; --pink-light: #f3dde4; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .section-label { display: inline-block; background: rgba(216,167,177,.12); color: #d8a7b1; font-family: 'Montserrat', sans-serif !important; font-size: 12px !important; font-weight: 700; padding: 4px 14px; border-radius: 20px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1.2px; }
  .section-title { text-align: center; font-size: 34px !important; margin-bottom: 8px; font-family: 'Montserrat', sans-serif !important; }
  .section-subtitle { text-align: center; color: #666; margin-bottom: 44px; font-size: 16px !important; }
  .testimonials-section { padding: 70px 0; background: var(--pink-light); overflow: hidden; }
  .testimonials-section > .container { padding-bottom: 40px; }
  .carousel-wrapper { overflow: hidden; cursor: grab; }
  .carousel-wrapper.is-dragging { cursor: grabbing; user-select: none; }
  .carousel-row { display: flex; width: max-content; gap: 20px; padding: 0 10px 20px; animation: scroll-left 38s linear infinite; }
  .carousel-row--right { animation: scroll-right 38s linear infinite; }
  @keyframes scroll-left { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @keyframes scroll-right { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
  .carousel-wrapper:hover .carousel-row { animation-play-state: paused; }
  .t-card { background: #fff; border-radius: 14px; padding: 24px; border: 1px solid #d4c4bc; position: relative; width: 360px; flex-shrink: 0; box-shadow: 0 2px 14px rgba(216,167,177,.08); }
  .t-card::before { content: '"'; position: absolute; top: -8px; left: 18px; font-size: 72px !important; color: var(--red); font-family: Georgia, serif; line-height: 1; opacity: .15; }
  .stars { color: var(--yellow); font-size: 16px !important; margin-bottom: 10px; }
  .t-text { font-size: 15px !important; color: #444; font-style: italic; margin-bottom: 16px; }
  .t-author { display: flex; align-items: center; gap: 11px; }
  .t-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; flex-shrink: 0; overflow: hidden; border: 2px solid rgba(216,167,177,.4); }
  .t-name { font-weight: 700; font-size: 14px !important; color: #222; }
  .t-city { font-size: 12px !important; color: #888; }
  .verified { display: inline-flex; align-items: center; gap: 3px; background: #f9f0f3; color: #a39384; font-size: 11px !important; font-weight: 700; padding: 2px 8px; border-radius: 10px; margin-top: 3px; }
  @media (max-width: 768px) { .t-card { width: 290px; } .section-title { font-size: 28px !important; } }
</style>

