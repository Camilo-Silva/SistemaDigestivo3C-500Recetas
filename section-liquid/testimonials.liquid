<script>
(function () {
    var wrapper = document.querySelector('.carousel-wrapper');
    if (!wrapper) return;
    var rows = Array.from(wrapper.querySelectorAll('.carousel-row'));
    var DURATION = 38;

    function getTranslateX(el) {
        var t = window.getComputedStyle(el).transform;
        if (!t || t === 'none') return 0;
        var vals = t.replace('matrix(', '').replace(')', '').split(',');
        return parseFloat(vals[4]) || 0;
    }

    function resumeRows(finalXArr) {
        rows.forEach(function (row, i) {
            var halfWidth = row.scrollWidth / 2;
            var isRight   = row.classList.contains('carousel-row--right');
            var progress  = isRight
                ? (finalXArr[i] + halfWidth) / halfWidth
                : -finalXArr[i] / halfWidth;
            progress = Math.max(0, Math.min(1, progress));
            row.style.animationDelay     = -(progress * DURATION) + 's';
            row.style.transform          = '';
            row.style.animationName      = '';
            row.style.animationPlayState = 'running';
        });
    }

    var isDown    = false;
    var startX    = 0;
    var startY    = 0;
    var startArr  = [];
    var direction = null;

    function clientX(e) { return e.touches ? e.touches[0].clientX : e.clientX; }
    function clientY(e) { return e.touches ? e.touches[0].clientY : e.clientY; }

    wrapper.addEventListener('mouseleave', function () {
        if (isDown) return;
        rows.forEach(function (row) { row.style.animationPlayState = ''; });
    });

    function onStart(e) {
        isDown    = true;
        startX    = clientX(e);
        startY    = clientY(e);
        direction = null;
        startArr  = rows.map(getTranslateX);
    }

    function onMove(e) {
        if (!isDown) return;
        var dx = clientX(e) - startX;
        var dy = clientY(e) - startY;
        if (direction === null && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) {
            direction = Math.abs(dx) >= Math.abs(dy) ? 'h' : 'v';
            if (direction === 'h') {
                rows.forEach(function (row, i) {
                    row.style.animationName = 'none';
                    row.style.transform     = 'translateX(' + startArr[i] + 'px)';
                });
                wrapper.classList.add('is-dragging');
            }
        }
        if (direction === 'h') {
            e.preventDefault();
            rows.forEach(function (row, i) {
                row.style.transform = 'translateX(' + (startArr[i] + dx) + 'px)';
            });
        }
    }

    function onEnd(e) {
        if (!isDown) return;
        isDown = false;
        if (direction === 'h') {
            wrapper.classList.remove('is-dragging');
            var cx    = e.changedTouches ? e.changedTouches[0].clientX : e.clientX;
            var delta = cx - startX;
            resumeRows(startArr.map(function (x) { return x + delta; }));
        }
        direction = null;
    }

    wrapper.addEventListener('mousedown',  onStart);
    window.addEventListener('mousemove',   onMove);
    window.addEventListener('mouseup',     onEnd);
    wrapper.addEventListener('touchstart', onStart, { passive: true });
    window.addEventListener('touchmove',   onMove,  { passive: false });
    window.addEventListener('touchend',    onEnd);
})();
</script>

