<script>
(function () {
  var wrapper = document.querySelector('.sd3c-carousel-wrapper');
  if (!wrapper) return;
  var rows = Array.from(wrapper.querySelectorAll('.sd3c-carousel-row'));
  var DURATION = 38;

  function getTranslateX(el) {
    var t = window.getComputedStyle(el).transform;
    if (!t || t === 'none') return 0;
    var vals = t.replace('matrix(', '').replace(')', '').split(',');
    return parseFloat(vals[4]) || 0;
  }

  function resumeRows(finalXArr) {
    rows.forEach(function (row, i) {
      var isRight = row.classList.contains('sd3c-carousel-row--right');
      var D = row.scrollWidth / 2;
      var currentX = finalXArr[i];
      var animName = isRight ? 'sd3cScrollRight' : 'sd3cScrollLeft';
      var t = isRight ? DURATION * (currentX / D + 1) : -currentX * DURATION / D;
      t = ((t % DURATION) + DURATION) % DURATION;
      row.style.transform = '';
      row.style.animation = animName + ' ' + DURATION + 's linear -' + t.toFixed(3) + 's infinite';
    });
  }

  var isDown = false, startX = 0, startY = 0, startArr = [], direction = null;
  function clientX(e) { return e.touches ? e.touches[0].clientX : e.clientX; }
  function clientY(e) { return e.touches ? e.touches[0].clientY : e.clientY; }

  wrapper.addEventListener('mouseleave', function () {
    if (isDown) return;
    rows.forEach(function (row) { row.style.animationPlayState = ''; });
  });

  function onStart(e) { isDown = true; startX = clientX(e); startY = clientY(e); direction = null; startArr = rows.map(getTranslateX); }
  function onMove(e) {
    if (!isDown) return;
    var dx = clientX(e) - startX, dy = clientY(e) - startY;
    if (direction === null && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) {
      direction = Math.abs(dx) >= Math.abs(dy) ? 'h' : 'v';
      if (direction === 'h') { rows.forEach(function (row) { row.style.animation = 'none'; }); wrapper.classList.add('is-dragging'); }
    }
    if (direction === 'h') {
      if (e.cancelable) e.preventDefault();
      rows.forEach(function (row, i) { row.style.transform = 'translateX(' + (startArr[i] + dx) + 'px)'; });
    }
  }
  function onEnd() {
    if (!isDown) return; isDown = false;
    if (direction === 'h') { wrapper.classList.remove('is-dragging'); resumeRows(rows.map(getTranslateX)); }
    direction = null;
  }

  wrapper.addEventListener('mousedown',  onStart);
  window.addEventListener('mousemove',   onMove);
  window.addEventListener('mouseup',     onEnd);
  wrapper.addEventListener('touchstart', onStart, { passive: true });
  window.addEventListener('touchmove',   onMove,  { passive: false });
  window.addEventListener('touchend',    onEnd);
})();
</script>

