<style>
  :root {
    --verde: #7a9d8e;
    --verde-claro: #9dbcb3;
    --verde-fondo: #eaf4f0;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --blanco: #FFFFFF;
    --fondo: #f9f0f3;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; line-height: 1.65; }
  .sd3c-container { max-width: 780px; margin: 0 auto; padding: 0 20px; }
  .sd3c-tag-verde {
    display: inline-block; background: var(--verde-fondo); color: var(--verde);
    font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    padding: 4px 12px; border-radius: 99px; margin-bottom: 16px;
  }
  .sd3c-test-h2 { font-size: clamp(24px, 4vw, 36px); font-weight: 800; margin-bottom: 8px; line-height: 1.25; }
  .sd3c-subtitulo { font-size: clamp(16px, 2vw, 20px); color: var(--gris-medio); margin-bottom: 32px; }
  .sd3c-testimonials-section { padding: 72px 0; background: var(--fondo); overflow: hidden; }
  .sd3c-testimonials-section > .sd3c-container { padding-bottom: 40px; }
  .sd3c-carousel-wrapper { overflow: hidden; cursor: grab; }
  .sd3c-carousel-wrapper.is-dragging { cursor: grabbing; user-select: none; }
  .sd3c-carousel-row {
    display: flex; width: max-content; gap: 20px;
    padding: 0 10px 20px;
    animation: sd3cScrollLeft 38s linear infinite;
  }
  .sd3c-carousel-row--right { animation: sd3cScrollRight 38s linear infinite; }
  @keyframes sd3cScrollLeft  { 0% { transform: translateX(0);    } 100% { transform: translateX(-50%); } }
  @keyframes sd3cScrollRight { 0% { transform: translateX(-50%); } 100% { transform: translateX(0);    } }
  .sd3c-carousel-wrapper:hover .sd3c-carousel-row { animation-play-state: paused; }
  .sd3c-t-card {
    background: var(--blanco); border-radius: 14px; padding: 24px;
    border: 1px solid #d4c4bc; position: relative; width: 360px;
    flex-shrink: 0; box-shadow: 0 2px 14px rgba(122,157,142,.08);
    transition: transform .22s ease, box-shadow .22s ease;
  }
  .sd3c-t-card:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 8px 24px rgba(0,0,0,.12); }
  .sd3c-t-card::before {
    content: '"'; position: absolute; top: -8px; left: 18px;
    font-size: 4.5rem; color: var(--verde); font-family: Georgia, serif;
    line-height: 1; opacity: .15;
  }
  .sd3c-stars { color: #f5a623; font-size: 1rem; margin-bottom: 10px; }
  .sd3c-t-text { font-size: .93rem; color: #444; font-style: italic; margin-bottom: 16px; }
  .sd3c-t-author { display: flex; align-items: center; gap: 11px; }
  .sd3c-t-avatar {
    width: 44px; height: 44px; border-radius: 50%; object-fit: cover;
    flex-shrink: 0; overflow: hidden; border: 2px solid rgba(122,157,142,.4);
  }
  .sd3c-t-name { font-weight: 700; font-size: .88rem; color: #222; }
  .sd3c-t-city { font-size: .78rem; color: #888; }
  .sd3c-verified {
    display: inline-flex; align-items: center; gap: 3px;
    background: var(--verde-fondo); color: var(--verde);
    font-size: .7rem; font-weight: 700; padding: 2px 8px;
    border-radius: 10px; margin-top: 3px;
  }
  @media (max-width: 600px) { .sd3c-t-card { width: 290px; } }
</style>

