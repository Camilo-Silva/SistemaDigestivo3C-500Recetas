<script>
(function () {
  var carousel = document.getElementById('bonus-carousel');
  if (!carousel) return;
  var track    = document.getElementById('bc-track');
  var slides   = Array.from(carousel.querySelectorAll('.bc-slide'));
  var dotsWrap = document.getElementById('bc-dots');
  var total    = slides.length;
  var current  = 0;
  var autoTimer;
  var INTERVAL = 7000;
  var paused   = false;

  slides.forEach(function (_, i) {
    var dot = document.createElement('button');
    dot.className = 'bc-dot' + (i === 0 ? ' bc-dot--active' : '');
    dot.setAttribute('aria-label', 'Ir a ' + (i + 1));
    dot.addEventListener('click', function () { goTo(i); resetTimer(); });
    dotsWrap.appendChild(dot);
  });

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    carousel.querySelectorAll('.bc-dot').forEach(function (d, i) {
      d.classList.toggle('bc-dot--active', i === current);
    });
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function resetTimer() {
    clearInterval(autoTimer);
    if (!paused) autoTimer = setInterval(next, INTERVAL);
  }

  carousel.querySelector('.bc-prev').addEventListener('click', function () { prev(); resetTimer(); });
  carousel.querySelector('.bc-next').addEventListener('click', function () { next(); resetTimer(); });

  var touchStartX = 0;
  carousel.addEventListener('touchstart', function (e) {
    touchStartX = e.touches[0].clientX;
    paused = true; clearInterval(autoTimer);
  }, { passive: true });
  carousel.addEventListener('touchend', function (e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { diff > 0 ? next() : prev(); }
    paused = false; resetTimer();
  }, { passive: true });

  carousel.addEventListener('mousedown',  function () { paused = true;  clearInterval(autoTimer); });
  carousel.addEventListener('mouseup',    function () { paused = false; resetTimer(); });
  carousel.addEventListener('mouseleave', function () { paused = false; resetTimer(); });

  resetTimer();

  /* Descripción expandible */
  carousel.querySelectorAll('.bc-desc').forEach(function (desc) {
    var originalText = desc.innerHTML;
    desc.innerHTML = '<span class="bc-desc-text">' + originalText + '</span>' +
      '<button class="bc-desc-toggle">Ver más ▾</button>';
    var textEl    = desc.querySelector('.bc-desc-text');
    var toggleBtn = desc.querySelector('.bc-desc-toggle');
    toggleBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var expanded = textEl.classList.toggle('expanded');
      toggleBtn.textContent = expanded ? 'Ver menos ▴' : 'Ver más ▾';
    });
  });
})();
</script>

