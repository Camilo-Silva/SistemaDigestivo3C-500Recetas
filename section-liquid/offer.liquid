<style>
  :root { --red: #d8a7b1; --red-dark: #b8879a; --dark: #2c1f1b; --text: #4a3a32; --cream: #f1ebe5; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  @keyframes shimmer { 0% { left: -100%; } 100% { left: 200%; } }
  .section-label { display: inline-block; background: rgba(216,167,177,.12); color: var(--red-dark); font-family: 'Montserrat', sans-serif !important; font-size: 12px !important; font-weight: 700; padding: 4px 14px; border-radius: 20px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1.2px; }
  .section-title { text-align: center; font-size: 34px !important; margin-bottom: 8px; font-family: 'Montserrat', sans-serif !important; color: var(--dark); }
  .section-subtitle { text-align: center; color: #555; margin-bottom: 44px; font-size: 16px !important; }
  .offer-section { background: var(--cream); color: var(--text); text-align: center; }
  .offer-band { padding: 50px 5px; }
  .offer-band--dark { background: var(--cream); color: var(--dark); padding: 50px 20px; }
  .bonus-carousel { position: relative; max-width: 100%; margin: 0 auto; padding: 0; }
  .bc-track-wrapper { overflow: hidden; border-radius: 16px; }
  .bc-track { display: flex; transition: transform .7s cubic-bezier(.4,0,.2,1); will-change: transform; }
  .bc-slide { min-width: 100%; }
  .bc-card { background: #fff; border: 2px solid rgba(216,167,177,.25); border-radius: 16px; text-align: center; display: flex; flex-direction: column; align-items: center; box-shadow: 0 4px 18px rgba(216,167,177,.10); overflow: hidden; }
  .bc-mockup { width: 100%; background: #f9f0f3; display: flex; align-items: center; justify-content: center; overflow: hidden; border-bottom: 2px solid rgba(216,167,177,.15); min-height: 200px; }
  .bc-mockup img { width: 100%; height: auto; display: block; object-fit: cover; }
  .bc-body { padding: 28px 28px 32px; display: flex; flex-direction: column; align-items: center; width: 100%; }
  .bc-name { font-family: 'Montserrat', sans-serif !important; font-weight: 700; font-size: 18px !important; color: var(--dark); margin-bottom: 12px; line-height: 1.35; max-width: 70%; }
  .bc-badge { display: inline-block; background: rgba(216,167,177,.12); color: var(--red-dark); font-size: 12px !important; font-weight: 700; padding: 4px 14px; border-radius: 10px; margin-bottom: 10px; }
  .bc-desc { font-size: 14px !important; color: #666; margin-top: 8px; line-height: 1.6; }
  .bc-desc-text { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; transition: none; }
  .bc-desc-text.expanded { display: block; -webkit-line-clamp: unset; }
  .bc-desc-toggle { background: none; border: none; color: var(--red); font-size: 13px !important; font-weight: 700; cursor: pointer; padding: 4px 0 0; display: inline-block; font-family: 'Montserrat', sans-serif !important; }
  .bc-arrow { position: absolute; top: calc(50% - 22px); transform: translateY(-50%); width: 40px; height: 40px; border-radius: 50%; background: #fff; border: 2px solid rgba(216,167,177,.5); color: var(--red); font-size: 24px !important; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .2s, border-color .2s, transform .2s; z-index: 5; line-height: 1; box-shadow: 0 2px 10px rgba(0,0,0,.15); padding: 0; }
  .bc-arrow:hover { background: rgba(216,167,177,.12); border-color: var(--red); transform: translateY(-50%) scale(1.08); }
  .bc-prev { left: 5px; } .bc-next { right: 5px; }
  .bc-dots { display: flex; gap: 8px; justify-content: center; margin-top: 16px; }
  .bc-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(216,167,177,.25); border: none; cursor: pointer; transition: background .25s, transform .25s; padding: 0; }
  .bc-dot.bc-dot--active { background: var(--red); transform: scale(1.3); }
  .value-stack { margin-top: 32px; padding: 36px; background: rgba(255,255,255,.7); border: 2px solid #d8c8c0; border-radius: 16px; max-width: 760px; margin-left: auto; margin-right: auto; text-align: center; }
  .real-value { text-decoration: line-through; color: #a39384; font-size: 16px !important; font-weight: 600; margin-bottom: 8px; }
  .big-price { font-family: 'Montserrat', sans-serif !important; font-size: 51px !important; font-weight: 900; color: var(--red); line-height: 1; }
  .ars-price { font-size: 18px !important; color: #777; margin-top: 6px; }
  .cta-wrap { text-align: center; }
  .cta-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; background: linear-gradient(180deg, #e0b8c3, #d8a7b1); color: #fff; font-family: 'Montserrat', sans-serif !important; font-size: 19px !important; font-weight: 900; text-decoration: none; padding: 22px 36px; border-radius: 10px; text-transform: uppercase; letter-spacing: .5px; box-shadow: 0 8px 0 #b8879a, 0 12px 30px rgba(216,167,177,.4); transition: all .15s ease; max-width: 640px; width: 100%; margin: 10px auto; position: relative; overflow: hidden; }
  .cta-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 60%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent); animation: shimmer 2.5s infinite; }
  .cta-btn:hover { transform: translateY(3px); box-shadow: 0 5px 0 #b8879a, 0 8px 18px rgba(216,167,177,.3); }
  .cta-sub { font-size: 12px !important; color: #999; margin-top: 8px; }
  .cta-sub.light { color: rgba(255,255,255,.6); }
  @media (max-width: 768px) { .big-price { font-size: 38px !important; } .cta-btn { font-size: 16px !important; padding: 18px 18px; } .section-title { font-size: 28px !important; } }
</style>

