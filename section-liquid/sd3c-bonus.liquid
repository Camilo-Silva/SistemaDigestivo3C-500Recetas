<style>
  :root {
    --verde: #7a9d8e;
    --verde-claro: #9dbcb3;
    --verde-fondo: #eaf4f0;
    --rosa: #d8a7b1;
    --rojo: #c4757f;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --gris-suave: #a39384;
    --blanco: #FFFFFF;
    --fondo: #f1ebe5;
    --radio: 14px;
    --sombra: 0 4px 24px rgba(122,157,142,.12);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; }

  .sd3c-bonus-seccion { padding: 72px 0; background: var(--fondo); }
  .sd3c-bonus-container { max-width: 780px; margin: 0 auto; padding: 0 20px; }

  .sd3c-tag-amarillo { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 4px 12px; border-radius: 99px; margin-bottom: 16px; background: #f5e8ec; color: var(--rosa); }
  .sd3c-bonus-seccion h2 { font-size: clamp(26px,4vw,38px); margin-bottom: 16px; line-height: 1.25; }

  .sd3c-bonus-stack { display: flex; flex-direction: column; gap: 24px; margin-top: 36px; }

  .sd3c-bonus-card { background: var(--blanco); border-radius: var(--radio); box-shadow: var(--sombra); overflow: hidden; display: flex; gap: 0; }
  .sd3c-bonus-card .sd3c-banda { width: 8px; background: var(--verde-claro); flex-shrink: 0; }
  .sd3c-bonus-card.premium .sd3c-banda { background: linear-gradient(180deg, #d8a7b1, #c4757f); }
  .sd3c-bonus-card .sd3c-contenido { padding: 22px 22px 22px 20px; flex: 1; }

  .sd3c-badge-bonus { display: inline-block; font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; border-radius: 99px; padding: 3px 10px; margin-bottom: 10px; background: var(--verde-fondo); color: var(--verde); }
  .sd3c-bonus-card.premium .sd3c-badge-bonus { background: linear-gradient(90deg, #f5e8ec, #f5e4e6); color: var(--rojo); }
  .sd3c-bonus-card h4 { font-size: 18px; margin-bottom: 10px; line-height: 1.3; }
  .sd3c-bonus-card p { font-size: 15px; color: var(--gris-medio); line-height: 1.65; }

  .sd3c-bonus-img-full { width: 100%; max-width: 400px; border-radius: 10px; margin-top: 16px; display: block; }
  .sd3c-bonus-img-wide { width: 100%; border-radius: 10px; margin-top: 16px; display: block; }
  .sd3c-bonus-img-app  { width: 100%; border-radius: 12px; margin-top: 20px; margin-bottom: 20px; display: block; }

  /* Features grid app */
  .sd3c-app-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 14px; }
  .sd3c-app-feat { background: #f8f4f1; border-radius: 10px; padding: 16px 14px; }
  .sd3c-app-feat .ico { font-size: 26px; margin-bottom: 8px; }
  .sd3c-app-feat strong { font-size: 14px; display: block; margin-bottom: 4px; }
  .sd3c-app-feat p { font-size: 13px; color: var(--gris-suave); }

  /* Lista mercado */
  .sd3c-mercado-box { background: linear-gradient(135deg, #3d6b5e, #7a9d8e); color: #fff; border-radius: 12px; padding: 22px 20px; }
  .sd3c-mercado-box strong { font-size: 15px; display: block; margin-bottom: 10px; }
  .sd3c-mercado-box p { font-size: 14px; opacity: .85; margin-bottom: 14px; color: #fff; }
  .sd3c-dias-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
  .sd3c-dia-btn { background: rgba(255,255,255,.15); border-radius: 99px; padding: 6px 18px; font-size: 14px; font-weight: 700; }
  .sd3c-cats-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .sd3c-cat { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); border-radius: 99px; padding: 5px 14px; font-size: 13px; }

  /* reveal */
  .sd3c-bonus-reveal { opacity: 0; transform: translateY(22px); transition: opacity .5s, transform .5s; }
  .sd3c-bonus-reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<section class="sd3c-bonus-seccion">
  <div class="sd3c-bonus-container">
    <div class="sd3c-tag-amarillo">🎁 Bonus incluidos</div>
    <h2>Más de lo que esperabas</h2>

    <div class="sd3c-bonus-stack">

      <!-- Bonus 1: 500 Recetas -->
      <div class="sd3c-bonus-card sd3c-bonus-reveal">
        <div class="sd3c-banda"></div>
        <div class="sd3c-contenido">
          <span class="sd3c-badge-bonus">Bonus 1</span>
          <h4>📖 500 Recetas para comer sin pensar</h4>
          <p>El ebook completo con 500 recetas organizadas estratégicamente por <strong>tiempo</strong> (5, 10 o 20 min), <strong>momento del día</strong> y <strong>necesidad digestiva</strong>. No buscás recetas — el sistema te dice exactamente qué cocinar según tu situación real.</p>
          {% if section.settings.img_portada != blank %}
            <img class="sd3c-bonus-img-full" src="{{ section.settings.img_portada | img_url: 'master' }}" alt="500 Recetas para comer sin pensar — Portada">
          {% endif %}
        </div>
      </div>

      <!-- Bonus 2: Notion -->
      <div class="sd3c-bonus-card sd3c-bonus-reveal">
        <div class="sd3c-banda"></div>
        <div class="sd3c-contenido">
          <span class="sd3c-badge-bonus">Bonus 2 · Super Bonus</span>
          <h4>📋 Plantilla Notion con las 500 recetas</h4>
          <p>Todas las recetas en una base de datos Notion lista para usar. Filtrá por tiempo, tipo de comida o ingrediente con un clic. Siempre disponible, desde cualquier dispositivo, sin abrir el ebook.</p>
          {% if section.settings.img_notion != blank %}
            <img class="sd3c-bonus-img-wide" src="{{ section.settings.img_notion | img_url: 'master' }}" alt="Sistema de planificación de comidas organizado en Notion">
          {% endif %}
        </div>
      </div>

      <!-- Bonus 3: App Premium -->
      <div class="sd3c-bonus-card premium sd3c-bonus-reveal">
        <div class="sd3c-banda"></div>
        <div class="sd3c-contenido">
          <span class="sd3c-badge-bonus">Bonus 3 · Premium exclusivo</span>
          <h4>📱 App Vida en Calma — Acceso completo</h4>
          <p style="margin-bottom:18px;">El bonus más poderoso. Una app diseñada específicamente para que nunca más pienses qué comer. Incluye todas estas funcionalidades:</p>

          <div class="sd3c-app-grid">
            <div class="sd3c-app-feat">
              <div class="ico">🔎</div>
              <strong>Filtros inteligentes</strong>
              <p>Buscá por tiempo, momento del día o estado de ánimo. Las recetas aparecen al instante según lo que necesitás en ese momento.</p>
            </div>
            <div class="sd3c-app-feat">
              <div class="ico">🧑‍🍳</div>
              <strong>¿Qué cocino con esto?</strong>
              <p>Cargás tus ingredientes disponibles y la app te sugiere la mejor receta posible con lo que ya tenés.</p>
            </div>
            <div class="sd3c-app-feat">
              <div class="ico">⚡</div>
              <strong>¿No sé qué comer? → Un clic</strong>
              <p>Un botón que te sugiere una receta al azar en segundos. Sin pensar. Sin dudar. Lista para hacer ahora.</p>
            </div>
            <div class="sd3c-app-feat">
              <div class="ico">📅</div>
              <strong>Modo Automático</strong>
              <p>Resolvemos tu día completo: desayuno, almuerzo, merienda y cena. Un clic y listo. Cero decisiones.</p>
            </div>
            <div class="sd3c-app-feat">
              <div class="ico">🛒</div>
              <strong>Lista de mercado inteligente</strong>
              <p>Creá tu lista personalizada con los productos que usás, o pedile a la app que te la genere automáticamente según cuántos días vas a cocinar.</p>
            </div>
          </div>

          {% if section.settings.img_app != blank %}
            <img class="sd3c-bonus-img-app" src="{{ section.settings.img_app | img_url: 'master' }}" alt="App Vida en Calma — decisiones fáciles">
          {% endif %}

          <div class="sd3c-mercado-box">
            <strong>🗓 Lista de mercado por días</strong>
            <p>Elegís para cuántos días querés cocinar y la app te genera automáticamente una lista completa, subdividida por categorías:</p>
            <div class="sd3c-dias-row">
              <span class="sd3c-dia-btn">3 días</span>
              <span class="sd3c-dia-btn">5 días</span>
              <span class="sd3c-dia-btn">7 días</span>
            </div>
            <div class="sd3c-cats-row">
              <span class="sd3c-cat">🥩 Proteínas</span>
              <span class="sd3c-cat">🥦 Verduras</span>
              <span class="sd3c-cat">🍎 Frutas</span>
              <span class="sd3c-cat">🌾 Carbohidratos</span>
              <span class="sd3c-cat">🥑 Grasas y semillas</span>
              <span class="sd3c-cat">🧄 Condimentos</span>
              <span class="sd3c-cat">💧 Líquidos</span>
              <span class="sd3c-cat">📦 Otros</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('.sd3c-bonus-reveal');
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e, i) {
      if (e.isIntersecting) {
        setTimeout(function () { e.target.classList.add('visible'); }, i * 160);
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function (el) { io.observe(el); });
})();
</script>

{% schema %}
{
  "name": "SD3C Bonus",
  "settings": [
    {
      "type": "image_picker",
      "id": "img_portada",
      "label": "Bonus 1 — Portada recetario",
      "info": "Subir: Portada.jpg"
    },
    {
      "type": "image_picker",
      "id": "img_notion",
      "label": "Bonus 2 — Captura plantilla Notion",
      "info": "Subir: Sistema de planificación de comidas organizado.png"
    },
    {
      "type": "image_picker",
      "id": "img_app",
      "label": "Bonus 3 — App Vida en Calma",
      "info": "Subir: App Vida en Calma_ decisiones fáciles.png"
    }
  ],
  "presets": [
    {
      "name": "SD3C Bonus"
    }
  ]
}
{% endschema %}
