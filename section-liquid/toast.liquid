<style>
  :root { --green-mid: #d8a7b1; }
  .toast-container {
    position: fixed;
    top: 60px;
    right: 14px;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 7px;
    pointer-events: none;
  }
  .toast {
    background: #fff;
    border-left: 3px solid #d8a7b1;
    border-radius: 8px;
    padding: 8px 11px;
    box-shadow: 0 4px 16px rgba(0,0,0,.14);
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 240px;
    font-size: 12px !important;
    animation: toastIn .3s ease forwards;
    font-family: 'Open Sans', sans-serif !important;
  }
  .toast.out { animation: toastOut .3s ease forwards; }
  .t-av {
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif !important; font-weight: 700;
    font-size: 12px !important; color: #fff; flex-shrink: 0;
  }
  .toast-body strong { display: block; color: #111; font-size: 12px !important; line-height: 1.2; }
  .toast-body span   { color: #666; font-size: 12px !important; }
  .toast-check { color: #d8a7b1; font-size: 15px !important; margin-left: auto; flex-shrink: 0; }
  @keyframes toastIn  { from { opacity: 0; transform: translateX(28px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes toastOut { from { opacity: 1; transform: translateX(0); } to { opacity: 0; transform: translateX(28px); } }
</style>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<div class="toast-container" id="toastContainer"></div>

<script>
(function () {
  var buyers = [
    { name: 'Valentina M.',  city: 'Buenos Aires',  ini: 'VM', bg: 'linear-gradient(135deg,#d8a7b1,#a39384)' },
    { name: 'Lucía R.',      city: 'Córdoba',        ini: 'LR', bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Sofía P.',      city: 'Rosario',        ini: 'SP', bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' },
    { name: 'Camila F.',     city: 'Mendoza',        ini: 'CF', bg: 'linear-gradient(135deg,#e07b00,#c45c00)' },
    { name: 'Florencia B.',  city: 'Mar del Plata',  ini: 'FB', bg: 'linear-gradient(135deg,#007bc1,#005a8e)' },
    { name: 'Martina T.',    city: 'Salta',          ini: 'MT', bg: 'linear-gradient(135deg,#1a1f71,#3546c5)' },
    { name: 'Julieta C.',    city: 'La Plata',       ini: 'JC', bg: 'linear-gradient(135deg,#d8a7b1,#a39384)' },
    { name: 'Paula A.',      city: 'Tucumán',        ini: 'PA', bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Romina G.',     city: 'Santa Fe',       ini: 'RG', bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' },
    { name: 'Agustina L.',   city: 'Bahía Blanca',   ini: 'AL', bg: 'linear-gradient(135deg,#e07b00,#c45c00)' },
    { name: 'Carolina V.',   city: 'San Juan',       ini: 'CV', bg: 'linear-gradient(135deg,#007bc1,#005a8e)' },
    { name: 'Micaela H.',    city: 'Neuquén',        ini: 'MH', bg: 'linear-gradient(135deg,#1a1f71,#3546c5)' },
    { name: 'Natalia S.',    city: 'Paraná',         ini: 'NS', bg: 'linear-gradient(135deg,#d8a7b1,#a39384)' },
    { name: 'Gabriela M.',   city: 'Resistencia',    ini: 'GM', bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Verónica P.',   city: 'La Rioja',       ini: 'VP', bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' }
  ];
  var times = ['hace 1 min', 'hace 2 min', 'hace 3 min', 'hace 5 min', 'recién ahora', 'hace 8 min'];
  var container = document.getElementById('toastContainer');
  var idx = Math.floor(Math.random() * buyers.length);

  function showToast() {
    var b   = buyers[idx % buyers.length]; idx++;
    var t   = times[Math.floor(Math.random() * times.length)];
    var div = document.createElement('div');
    div.className = 'toast';
    div.innerHTML =
      '<div class="t-av" style="background:' + b.bg + '">' + b.ini + '</div>' +
      '<div class="toast-body">' +
      '<strong>' + b.name + ' de ' + b.city + '</strong>' +
      '<span>acaba de iniciar su reset — ' + t + '</span>' +
      '</div>' +
      '<div class="toast-check">✔</div>';
    container.appendChild(div);
    setTimeout(function () {
      div.classList.add('out');
      setTimeout(function () { div.remove(); }, 380);
    }, 4800);
  }

  setTimeout(function () {
    showToast();
    setInterval(showToast, 25000 + Math.random() * 15000);
  }, 30000);
})();
</script>

