<style>
  :root { --red: #d8a7b1; --red-dark: #b8879a; --dark: #2c1f1b; --text: #4a3a32; --cream: #f1ebe5; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .closing-section { background: linear-gradient(135deg, #f9f0f3, #ede5e1); padding: 60px 20px; text-align: center; border-top: 1px solid #d8c8c0; }
  .closing-section h2 { font-size: 32px !important; color: var(--dark); margin-bottom: 14px; font-family: 'Montserrat', sans-serif !important; }
  .closing-section p { font-size: 17px !important; color: #d8a7b1; max-width: 600px; margin: 0 auto 10px; }
  .closing-punch { font-family: 'Montserrat', sans-serif !important; font-weight: 900; font-size: 22px !important; color: var(--red); margin: 18px 0 32px; }
  @media (max-width: 768px) { .closing-section h2 { font-size: 26px !important; } }
</style>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css' | stylesheet_tag }}

<section class="closing-section">
    <div class="container">
        <h2>{{ section.settings.headline }}</h2>
        <p>{{ section.settings.body_1 }}</p>
        <p class="closing-punch">{{ section.settings.punch }}</p>
        <p style="font-size: 15px !important;color:#555;max-width:500px;margin:0 auto;">{{ section.settings.body_2 }}</p>
    </div>
</section>

{% schema %}
{
  "name": "Cierre",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "No necesitás más información."
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Párrafo 1",
      "default": "Sabés que algo tiene que cambiar. Tenés el dolor, tenés las ganas — lo que te faltaba era el sistema correcto."
    },
    {
      "type": "text",
      "id": "punch",
      "label": "Frase punch",
      "default": "👉 Este es ese sistema."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Párrafo 2",
      "default": "Diseñado para tu vida real. Sin cocinar. Sin tiempo extra. Con resultados en 14 días."
    }
  ],
  "presets": [
    {
      "name": "Cierre"
    }
  ]
}
{% endschema %}
