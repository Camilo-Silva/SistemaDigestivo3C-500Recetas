<style>
  :root {
    --verde: #7a9d8e;
    --verde-claro: #9dbcb3;
    --verde-fondo: #eaf4f0;
    --rosa: #d8a7b1;
    --rojo: #c4757f;
    --gris-oscuro: #1C1C1E;
    --gris-medio: #4A4A4A;
    --blanco: #FFFFFF;
    --fondo: #f1ebe5;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; }

  .sd3c-extras-section { background: #fdf8f2; padding: 72px 20px; border-top: 3px solid #ead5be; }
  .sd3c-extras-tag { display: inline-block; background: #f5e4e6; color: var(--rojo); font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 4px 12px; border-radius: 99px; margin-bottom: 16px; }
  .sd3c-extras-heading { font-size: clamp(22px,4vw,34px); font-weight: 900; margin-bottom: 10px; }
  .sd3c-extras-sub { font-size: clamp(15px,2vw,18px); color: var(--gris-medio); margin-bottom: 0; max-width: 640px; }
  .sd3c-ep-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 36px; }
  .sd3c-ep-card { background: var(--blanco); border-radius: 14px; border: 1px solid #e2d3cc; box-shadow: 0 3px 18px rgba(0,0,0,.07); display: flex; flex-direction: column; transition: transform .22s, box-shadow .22s; }
  .sd3c-ep-card:hover { transform: translateY(-5px); box-shadow: 0 10px 32px rgba(122,157,142,.18); }
  .sd3c-ep-card-img { width: 100%; height: 180px; object-fit: contain; padding: 16px; background: #f9f5f2; border-radius: 14px 14px 0 0; }
  .sd3c-ep-card-body { padding: 16px 18px 20px; flex: 1; display: flex; flex-direction: column; }
  .sd3c-ep-card-title { font-weight: 800; font-size: .87rem; color: #111; margin-bottom: 6px; line-height: 1.3; }
  .sd3c-ep-card-details { margin-bottom: 12px; }
  .sd3c-ep-card-details summary { font-size: .75rem; font-weight: 700; color: var(--verde); cursor: pointer; list-style: none; display: flex; align-items: center; gap: 5px; padding: 4px 0; user-select: none; }
  .sd3c-ep-card-details summary::before { content: '▶'; font-size: .6rem; transition: transform .2s; }
  .sd3c-ep-card-details[open] summary::before { transform: rotate(90deg); }
  .sd3c-ep-card-details summary::-webkit-details-marker { display: none; }
  .sd3c-ep-card-desc { font-size: .78rem; color: #888; line-height: 1.5; margin-top: 8px; }
  .sd3c-ep-price-row { display: flex; align-items: center; gap: 8px; margin-top: auto; }
  .sd3c-ep-price-old { font-size: .85rem; color: #bbb; text-decoration: line-through; font-weight: 600; }
  .sd3c-ep-badge { background: var(--verde-fondo); color: var(--verde); font-weight: 800; font-size: .72rem; padding: 3px 10px; border-radius: 20px; border: 1.5px solid var(--verde-claro); }
  .sd3c-ep-total-bar { background: linear-gradient(135deg, #3d6b5e, var(--verde)); color: var(--blanco); border-radius: 14px; padding: 22px 28px; margin-top: 36px; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px; }
  .sd3c-ep-total-bar .ep-t-label { font-size: .92rem; opacity: .82; }
  .sd3c-ep-total-bar .ep-t-value { font-size: 1.6rem; font-weight: 900; }

  .sd3c-extras-reveal { opacity: 0; transform: translateY(18px); transition: opacity .5s, transform .5s; }
  .sd3c-extras-reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 400px) {
    .sd3c-ep-grid { grid-template-columns: 1fr; }
  }
</style>

{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css' | stylesheet_tag }}

