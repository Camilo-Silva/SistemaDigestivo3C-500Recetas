<style>
  .cta-main-btn-wrap {
    text-align: center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: #ffffff;
  }
  .cta-main-btn {
    display: inline-block;
    width: 100%;
    max-width: 460px;
    background: #07AB00;
    color: #FFFFFF;
    text-align: center;
    font-size: 16px;
    font-weight: 800;
    border-radius: 99px;
    padding: 16px 28px;
    box-shadow: 0 8px 32px rgba(7,171,0,.30);
    cursor: pointer;
    text-decoration: none;
    font-family: 'Segoe UI', system-ui, sans-serif;
    transition: transform .15s, box-shadow .15s;
    box-sizing: border-box;
  }
  .cta-main-btn:hover {
    transform: scale(1.03) translateY(-2px);
    box-shadow: 0 14px 44px rgba(7,171,0,.45);
  }
</style>

<div class="cta-main-btn-wrap">
  <a href="{% if section.settings.open_upsell %}#upsell-modal{% else %}{{ section.settings.cta_url }}{% endif %}"
     class="cta-main-btn">
    {{ section.settings.cta_text }}
  </a>
</div>

{% schema %}
{
  "name": "CTA Main Botón",
  "settings": [
    {
      "type": "checkbox",
      "id": "open_upsell",
      "label": "Abrir modal de upsell al hacer clic",
      "info": "Actívalo si usas la sección 'Upsell Modal' en la página.",
      "default": false
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL directa (cuando el modal está desactivado)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "💚 Comprar Ahora"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado superior (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado inferior (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "CTA Main Botón"
    }
  ]
}
{% endschema %}
