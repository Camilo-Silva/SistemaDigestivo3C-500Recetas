<!-- ===== Testimonios Grafismo Fonético — Carrusel v2 ===== -->
<style>
  .gf2-wrap {
    font-family: system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, sans-serif;
    width: 100%;
    max-width: 620px;
    box-sizing: border-box;
    margin: 36px auto;
    padding: 0 20px;
    overflow: hidden;
  }
  .gf2-titulo {
    text-align: center;
    font-size: 21px;
    font-weight: 800;
    color: #3B2009;
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .gf2-subtitulo {
    text-align: center;
    font-size: 14px;
    color: #7A5C3A;
    margin: 0 0 24px;
  }
  .gf2-carousel-outer {
    position: relative;
    padding: 0 40px;
  }
  .gf2-carousel {
    overflow: hidden;
    border-radius: 18px;
  }
  .gf2-track {
    display: flex;
    transition: transform 0.4s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  .gf2-slide {
    min-width: 100%;
    box-sizing: border-box;
  }
  .gf2-card {
    background: #FFFDF8;
    border: 1px solid #E8C5A8;
    border-radius: 18px;
    padding: 24px 20px 20px;
    box-shadow: 0 3px 18px rgba(200,92,58,.07);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .gf2-card__stars {
    display: flex;
    gap: 2px;
  }
  .gf2-card__stars svg {
    width: 17px;
    height: 17px;
    fill: #f59e0b;
  }
  .gf2-card__quote {
    font-size: 15px;
    line-height: 1.7;
    color: #2c2c2c;
    font-style: italic;
    margin: 0;
  }
  .gf2-card__quote::before { content: '\201C'; }
  .gf2-card__quote::after  { content: '\201D'; }
  .gf2-card__resultado {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #F9F0E3;
    border-radius: 8px;
    padding: 7px 12px;
    font-size: 13px;
    font-weight: 600;
    color: #C85C3A;
  }
  .gf2-card__resultado svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: #C85C3A;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex: 0 0 15px;
  }
  .gf2-card__autor {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid #F0D9C8;
    padding-top: 12px;
  }
  .gf2-card__foto {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex: 0 0 48px;
    border: 2px solid #E8A87C;
    background: #F9F0E3;
  }
  .gf2-card__nombre {
    font-size: 14px;
    font-weight: 700;
    color: #3B2009;
    line-height: 1.2;
  }
  .gf2-card__meta {
    font-size: 12px;
    color: #7A5C3A;
    margin-top: 2px;
  }
  .gf2-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #FFFDF8;
    border: 1.5px solid #E8A87C;
    box-shadow: 0 2px 8px rgba(200,92,58,.10);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C85C3A;
    z-index: 2;
    padding: 0;
    transition: background .18s;
  }
  .gf2-btn:hover { background: #F9F0E3; }
  .gf2-btn--prev { left: 0; }
  .gf2-btn--next { right: 0; }
  .gf2-btn svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gf2-dots {
    display: flex;
    justify-content: center;
    gap: 7px;
    margin-top: 18px;
  }
  .gf2-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #E8C5A8;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .22s, transform .22s;
  }
  .gf2-dot.is-active {
    background: #C85C3A;
    transform: scale(1.45);
  }
  @media (max-width: 600px) {
    .gf2-wrap          { padding: 0 14px; margin: 28px auto; }
    .gf2-titulo        { font-size: 18px; }
    .gf2-subtitulo     { font-size: 13px; margin-bottom: 18px; }
    .gf2-carousel-outer{ padding: 0 38px; }
    .gf2-btn           { width: 30px; height: 30px; }
    .gf2-btn svg       { width: 13px; height: 13px; }
    .gf2-card          { padding: 18px 14px 14px; gap: 10px; }
    .gf2-card__quote   { font-size: 14px; }
    .gf2-card__resultado { font-size: 12px; padding: 6px 10px; }
    .gf2-card__foto    { width: 42px; height: 42px; flex: 0 0 42px; }
    .gf2-card__nombre  { font-size: 13px; }
    .gf2-dots          { margin-top: 14px; }
  }
</style>

