<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Historias reales – Grafismo Fonético</title>
<style>
  :root{
    --bg: #FDF5EC;
    --card:#FFFAF5;
    --text:#2D1407;
    --muted:#8B7355;
    --primary:#D4733A;
    --accent:#7a9d8e;
    --ring: rgba(212,115,58,.20);
    --soft: rgba(45,20,7,.06);
    --radius: 18px;
    --shadow: 0 10px 34px rgba(45,20,7,.10);
  }

  body{ margin:0; background:var(--bg); color:var(--text);
        font-family: system-ui,-apple-system,Segoe UI,Inter,Roboto,Arial,sans-serif; }

  .wrap{ width:min(1100px,92vw); margin:42px auto; }

  .title{ font-weight: 900; font-size: clamp(24px,3.6vw,36px); margin:0 0 18px; }
  .title .accent{ background:linear-gradient(90deg,var(--primary),var(--accent));
                  -webkit-background-clip:text; background-clip:text; color:transparent; }

  /* ======= Card unificada ======= */
  .card{
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border:1px solid rgba(2,6,23,.06);
    overflow:hidden;
  }

  .card-inner{
    display:grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px){
    .card-inner{ grid-template-columns: 1.05fr 1fr; }
  }

  /* ==== Media con flechas === */
  .media-wrap{
    position: relative;
    background: #F0E4D2;
    padding: 18px;
  }
  .media{
    position: relative;
    border-radius: 16px;
    overflow:hidden;
    box-shadow: 0 8px 26px var(--soft);
    aspect-ratio: 1 / 1;
    background:#00000008;
  }
  .media img{ width:100%; height:100%; object-fit:cover; display:block; }

  .badge{
    position:absolute; top:14px; left:14px;
    padding:6px 10px; font-size:12px; font-weight:700; color:#fff;
    border-radius:999px;
    background: linear-gradient(92deg,var(--primary),var(--accent));
    box-shadow:0 14px 28px rgba(0,0,0,.18);
  }

  /* Flechas a los lados de la imagen */
  .nav-btn{
    position:absolute; top:50%; transform:translateY(-50%);
    width:42px; height:42px; border-radius:999px;
    border:1px solid rgba(2,6,23,.10);
    background:#fff; box-shadow: var(--shadow);
    display:grid; place-items:center; cursor:pointer;
    transition: transform .18s ease, background .18s ease;
    z-index: 3;
  }
  .nav-btn:hover{ transform: translateY(-50%) scale(1.04); }
  .nav-prev{ left: 4px; }
  .nav-next{ right: 4px; }
  .nav-btn svg{ width:20px; height:20px; }

  /* ==== Panel de testimonio === */
  .testi{
    padding: clamp(16px,2.2vw,22px);
    display:grid; align-content:center;
    background:
      radial-gradient(1200px 200px at 0% 0%, rgba(212,115,58,.07), transparent 60%),
      radial-gradient(1200px 200px at 100% 100%, rgba(122,157,142,.07), transparent 60%);
  }

  .quote-mark{
    width: 34px; height: 34px;
    border-radius: 10px;
    display:grid; place-items:center;
    background: linear-gradient(92deg, #FDECD8, #E8F4EF);
    border: 1px solid rgba(212,115,58,.15);
    color: var(--primary); font-weight: 900;
    margin-bottom:10px;
  }

  .quote{ margin:0; font-size: clamp(15px, 2.2vw, 17px); line-height: 1.55; }
  .bullets{ margin: 10px 0 0; padding:0; list-style:none; color:#5C3D2A; font-size:14px; }
  .bullets li{ display:flex; align-items:flex-start; gap:8px; margin:6px 0; }
  .bullets li:before{
    content:""; display:inline-block; width:14px; height:14px; margin-top:3px;
    border-radius:4px; background: linear-gradient(90deg,var(--primary),var(--accent));
    mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="white" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>') center/12px 12px no-repeat;
  }
  .name{ margin:10px 0 0; color: var(--muted); font-size:13px; }

  /* ==== Paginación y nota ==== */
  .controls{
    display:flex; justify-content:center; align-items:center; gap:8px;
    padding:12px 0 0;
  }
  .dot{
    width:8px; height:8px; border-radius:999px; background:#cbd5e1; border:none; cursor:pointer;
    transition:transform .18s ease, background .18s ease;
  }
  .dot[aria-current="true"]{ background:var(--primary); transform:scale(1.18); }

  .note{
    display:flex; align-items:flex-start; gap:10px;
    font-size:12.5px; color:#8B7355;
    margin-top:14px;
    padding:10px 12px;
    border-radius:12px;
    background: #FFFAF5;
    border:1px dashed rgba(212,115,58,.25);
  }
  .note i{
    width:18px; height:18px; flex: 0 0 18px;
    background: linear-gradient(90deg,var(--primary),var(--accent));
    -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="white" d="M12 2a10 10 0 100 20 10 10 0 000-20Zm1 15h-2v-6h2v6Zm0-8h-2V7h2v2Z"/></svg>') center/contain no-repeat;
            mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="white" d="M12 2a10 10 0 100 20 10 10 0 000-20Zm1 15h-2v-6h2v6Zm0-8h-2V7h2v2Z"/></svg>') center/contain no-repeat;
  }

  /* ====== Carrusel (pista) ====== */
  .track{ overflow:hidden; }
  .slides{
    display:grid; grid-auto-flow: column; grid-auto-columns: 100%;
    transition: transform .45s ease;
  }

  /* ayuda visual al arrastrar */
  .dragging .media{ cursor:grabbing; }
</style>
</head>
<body>

<div class="wrap" id="antiDieta">
