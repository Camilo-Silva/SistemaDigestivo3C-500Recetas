<script>
(function(){
  const root = document.getElementById('antiDieta');
  const slidesWrap = root.querySelector('.slides');
  const cards = Array.from(root.querySelectorAll('.card'));
  const controls = root.querySelector('.controls');

  // Config
  const AUTOPLAY = true;     // ← poner false si no querés autoplay
  const INTERVAL = 4800;

  let index = 0, timer = null;

  // Construir puntos
  cards.forEach((_, i)=>{
    const b = document.createElement('button');
    b.className = 'dot';
    b.type = 'button';
    b.setAttribute('aria-label','Ir al testimonio '+(i+1));
    if(i===0) b.setAttribute('aria-current','true');
    b.addEventListener('click', ()=> goTo(i));
    controls.appendChild(b);
  });
  const dots = Array.from(root.querySelectorAll('.dot'));

  function goTo(i){
    index = (i + cards.length) % cards.length;
    slidesWrap.style.transform = `translateX(-${index*100}%)`;
    dots.forEach((d,k)=> k===index ? d.setAttribute('aria-current','true') : d.removeAttribute('aria-current'));
    restart();
  }
  function next(){ goTo(index+1); }
  function prev(){ goTo(index-1); }

  // Flechas (dentro de cada media)
  root.querySelectorAll('.nav-next').forEach(btn=> btn.addEventListener('click', next));
  root.querySelectorAll('.nav-prev').forEach(btn=> btn.addEventListener('click', prev));

  // Teclado
  root.addEventListener('keydown', (e)=>{
    if(e.key==='ArrowRight') next();
    if(e.key==='ArrowLeft') prev();
  });

  // Drag / Swipe
  const track = root.querySelector('.track');
  let startX=0, curX=0, dragging=false;

  const start = (x)=>{ dragging=true; startX=curX=x; root.classList.add('dragging'); };
  const move  = (x)=>{ if(!dragging) return; curX=x; };
  const end   = ()=>{ if(!dragging) return; const dx=curX-startX; if(Math.abs(dx)>45) (dx<0?next():prev()); dragging=false; root.classList.remove('dragging'); };

  track.addEventListener('mousedown', e=> start(e.clientX));
  window.addEventListener('mousemove', e=> move(e.clientX));
  window.addEventListener('mouseup', end);

  track.addEventListener('touchstart', e=> start(e.touches[0].clientX), {passive:true});
  track.addEventListener('touchmove',  e=> move(e.touches[0].clientX), {passive:true});
  track.addEventListener('touchend', end);

  // Autoplay
  function restart(){
    if(!AUTOPLAY) return;
    clearInterval(timer);
    timer = setInterval(next, INTERVAL);
  }
  if (AUTOPLAY) restart();

  ['mouseenter','focusin'].forEach(evt=> root.addEventListener(evt, ()=> clearInterval(timer)));
  ['mouseleave','focusout'].forEach(evt=> root.addEventListener(evt, ()=> AUTOPLAY && restart()));

  // inicio
  goTo(0);
})();
</script>

</body>
