      <!-- ===== Slide 2 ===== -->
      <article class="card" role="group" aria-roledescription="slide" aria-label="2 de 3">
        <div class="card-inner">
          <div class="media-wrap">
            <button class="nav-btn nav-prev" aria-label="Anterior" type="button">
              <svg viewBox="0 0 24 24"><path d="M15.5 19l-7-7 7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="media">
              <img src="https://randomuser.me/api/portraits/women/52.jpg"
