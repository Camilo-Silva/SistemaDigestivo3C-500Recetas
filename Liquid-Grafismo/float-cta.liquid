<style>
  :root {
    --verde-cta: #07AB00;
    --blanco: #FFFFFF;
  }
  @keyframes sd3cFloatPulse {
    0%,100% { transform: translateX(-50%) scale(1);    box-shadow: 0 8px 32px rgba(7,171,0,.30); }
    50%     { transform: translateX(-50%) scale(1.05); box-shadow: 0 12px 40px rgba(7,171,0,.45); }
  }
  .sd3c-float-cta {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999;
    width: min(460px, calc(100% - 32px));
    background: var(--verde-cta);
    color: var(--blanco);
    text-align: center;
    font-size: 16px;
    font-weight: 800;
    border-radius: 99px;
    padding: 16px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,.22);
    cursor: pointer;
    text-decoration: none;
    animation: sd3cFloatPulse 2s ease-in-out infinite;
    font-family: 'Segoe UI', system-ui, sans-serif;
  }
  .sd3c-float-cta:hover {
    animation: none;
    transform: translateX(-50%) scale(1.07) translateY(-2px);
    box-shadow: 0 14px 44px rgba(7,171,0,.50);
  }
</style>

{% if section.settings.open_upsell %}
  <a href="#upsell-modal" class="sd3c-float-cta">{{ section.settings.cta_text }}</a>
{% else %}
  <a href="{{ section.settings.cta_url }}" class="sd3c-float-cta">{{ section.settings.cta_text }}</a>
{% endif %}

{% schema %}
{
  "name": "SD3C Float CTA",
  "settings": [
    {
      "type": "checkbox",
      "id": "open_upsell",
      "label": "Abrir modal de upsell al hacer clic",
      "info": "Actívalo si usas la sección 'Upsell Modal' en la página.",
      "default": false
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón flotante (cuando el modal está desactivado)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "💚 COMPRAR AHORA — 50% OFF 💚"
    }
  ],
  "presets": [
    {
      "name": "SD3C Float CTA"
    }
  ]
}
{% endschema %}
