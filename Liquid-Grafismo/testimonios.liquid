<!-- ===== Testimonios Grafismo Fonético — Carrusel ===== -->
<style>
  .gf-testimonios {
    font-family: system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, sans-serif;
    max-width: 640px;
    width: 100%;
    box-sizing: border-box;
    margin: 40px auto;
    padding: 0 24px;
    overflow: hidden;
  }
  .gf-testimonios__titulo {
    text-align: center;
    font-size: 22px;
    font-weight: 700;
    color: #3B2009;
    margin: 0 0 6px;
  }
  .gf-testimonios__subtitulo {
    text-align: center;
    font-size: 15px;
    color: #7A5C3A;
    margin: 0 0 28px;
  }
  .gf-carousel-wrap {
    position: relative;
    padding: 0 28px;
  }
  .gf-carousel {
    overflow: hidden;
    border-radius: 16px;
  }
  .gf-carousel__track {
    display: flex;
    transition: transform 0.45s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  .gf-carousel__slide {
    min-width: 100%;
    box-sizing: border-box;
  }
  .gf-card {
    background: #FFFDF8;
    border: 1px solid #E8C5A8;
    border-radius: 16px;
    padding: 28px 24px 22px;
    box-shadow: 0 4px 20px rgba(200,92,58,.08);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .gf-card__stars {
    display: flex;
    gap: 3px;
  }
  .gf-card__stars svg {
    width: 18px;
    height: 18px;
    fill: #f4a025;
  }
  .gf-card__texto {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
    font-style: italic;
    margin: 0;
  }
  .gf-card__texto::before { content: '\201C'; }
  .gf-card__texto::after  { content: '\201D'; }
  .gf-card__autor {
    display: flex;
    align-items: center;
    gap: 14px;
    border-top: 1px solid #F0D9C8;
    padding-top: 14px;
  }
  .gf-card__foto {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex: 0 0 52px;
    border: 2px solid #E8A87C;
    background: #F9F0E3;
  }
  .gf-card__nombre {
    font-size: 15px;
    font-weight: 700;
    color: #3B2009;
    line-height: 1.2;
  }
  .gf-card__lugar {
    font-size: 13px;
    color: #7A5C3A;
    margin-top: 2px;
  }
  .gf-card__tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    background: #F9F0E3;
    color: #C85C3A;
    border-radius: 999px;
    padding: 2px 10px;
    margin-top: 4px;
  }
  .gf-carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #FFFDF8;
    border: 1.5px solid #E8A87C;
    box-shadow: 0 2px 10px rgba(200,92,58,.12);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C85C3A;
    z-index: 2;
    padding: 0;
    transition: background .2s;
  }
  .gf-carousel__btn:hover { background: #F9F0E3; }
  .gf-carousel__btn--prev { left: 0; }
  .gf-carousel__btn--next { right: 0; }
  .gf-carousel__btn svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gf-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .gf-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #E8C5A8;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .25s, transform .25s;
  }
  .gf-carousel__dot.is-active {
    background: #C85C3A;
    transform: scale(1.4);
  }
  /* ---- Mobile first ---- */
  @media (max-width: 600px) {
    .gf-testimonios { padding: 0 16px; margin: 28px auto; }
    .gf-testimonios__titulo { font-size: 18px; }
    .gf-testimonios__subtitulo { font-size: 14px; margin-bottom: 20px; }
    .gf-carousel-wrap { padding: 0 36px; }
    .gf-carousel__btn { width: 30px; height: 30px; }
    .gf-carousel__btn--prev { left: 0; }
    .gf-carousel__btn--next { right: 0; }
    .gf-carousel__btn svg { width: 13px; height: 13px; }
    .gf-card { padding: 18px 14px 14px; gap: 10px; }
    .gf-card__texto { font-size: 14px; line-height: 1.65; }
    .gf-card__foto { width: 44px; height: 44px; flex: 0 0 44px; }
    .gf-card__nombre { font-size: 14px; }
    .gf-card__lugar { font-size: 12px; }
    .gf-carousel__dots { margin-top: 14px; gap: 7px; }
    .gf-carousel__dot { width: 7px; height: 7px; }
  }
</style>

