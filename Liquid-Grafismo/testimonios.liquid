<script>
(function () {
  var track  = document.getElementById('gfTrack');
  var prev   = document.getElementById('gfPrev');
  var next   = document.getElementById('gfNext');
  var dotsEl = document.getElementById('gfDots');
  if (!track || !prev || !next || !dotsEl) return;

  var slides  = track.querySelectorAll('.gf-carousel__slide');
  var total   = slides.length;
  var current = 0;
  var timer;

  slides.forEach(function (_, i) {
    var dot = document.createElement('button');
    dot.className = 'gf-carousel__dot' + (i === 0 ? ' is-active' : '');
    dot.setAttribute('aria-label', 'Testimonio ' + (i + 1));
    dot.setAttribute('role', 'tab');
    dot.addEventListener('click', function () { stop(); goTo(i); start(); });
    dotsEl.appendChild(dot);
  });

  function goTo(n) {
    current = (n + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dotsEl.querySelectorAll('.gf-carousel__dot').forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
    });
  }

  function start() { timer = setInterval(function () { goTo(current + 1); }, 8000); }
  function stop()  { clearInterval(timer); }

  prev.addEventListener('click', function () { stop(); goTo(current - 1); start(); });
  next.addEventListener('click', function () { stop(); goTo(current + 1); start(); });

  var sx = 0;
  track.parentElement.addEventListener('touchstart', function (e) { sx = e.touches[0].clientX; }, { passive: true });
  track.parentElement.addEventListener('touchend', function (e) {
    var dx = sx - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 40) { stop(); goTo(current + (dx > 0 ? 1 : -1)); start(); }
  }, { passive: true });

  track.parentElement.addEventListener('mouseenter', stop);
  track.parentElement.addEventListener('mouseleave', start);

  start();
}());
</script>
