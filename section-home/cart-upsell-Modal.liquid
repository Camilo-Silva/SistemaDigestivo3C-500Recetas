            {% if section.settings.p2_discount != blank %}
              <span class="upm-card-discount">{{ section.settings.p2_discount }}</span>
            {% endif %}
            {% if section.settings.p2_price_old != blank %}
              <span class="upm-card-price-old">{{ section.settings.p2_price_old }}</span>
            {% endif %}
          </div>
          {% if section.settings.p2_price_new != blank %}
            <span class="upm-card-price-new">{{ section.settings.p2_price_new }}</span>
          {% endif %}
        </div>
        <div class="upm-checkbox">
          <svg class="upm-checkbox-svg" viewBox="0 0 13 11" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
