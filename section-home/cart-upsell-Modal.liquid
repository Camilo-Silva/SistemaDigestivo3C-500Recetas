        {% else %}
          <div class="upm-card-img-empty"></div>
        {% endif %}
        <div class="upm-card-info">
          <div class="upm-card-name">{{ section.settings.p1_title }}</div>
          <div class="upm-card-pricing">
            {% if section.settings.p1_discount != blank %}
              <span class="upm-card-discount">{{ section.settings.p1_discount }}</span>
            {% endif %}
            {% if section.settings.p1_price_old != blank %}
              <span class="upm-card-price-old">{{ section.settings.p1_price_old }}</span>
            {% endif %}
          </div>
          {% if section.settings.p1_price_new != blank %}
            <span class="upm-card-price-new">{{ section.settings.p1_price_new }}</span>
