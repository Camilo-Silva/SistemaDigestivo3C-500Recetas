          <div class="upm-card-img-empty"></div>
        {% endif %}
        <div class="upm-card-info">
          <div class="upm-card-name">{{ section.settings.p3_title }}</div>
          <div class="upm-card-pricing">
            {% if section.settings.p3_discount != blank %}
              <span class="upm-card-discount">{{ section.settings.p3_discount }}</span>
            {% endif %}
            {% if section.settings.p3_price_old != blank %}
              <span class="upm-card-price-old">{{ section.settings.p3_price_old }}</span>
            {% endif %}
          </div>
