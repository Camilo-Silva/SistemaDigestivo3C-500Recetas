           data-discount="{{ section.settings.p4_discount }}">
        {% if section.settings.p4_image != blank %}
          <img src="{{ section.settings.p4_image | img_url: 'master' }}" alt="{{ section.settings.p4_title }}" class="upm-card-img">
        {% else %}
          <div class="upm-card-img-empty"></div>
        {% endif %}
        <div class="upm-card-info">
          <div class="upm-card-name">{{ section.settings.p4_title }}</div>
          <div class="upm-card-pricing">
            {% if section.settings.p4_discount != blank %}
              <span class="upm-card-discount">{{ section.settings.p4_discount }}</span>
            {% endif %}
            {% if section.settings.p4_price_old != blank %}
              <span class="upm-card-price-old">{{ section.settings.p4_price_old }}</span>
