      <p class="upm-subtitle">{{ section.settings.subtitle | default: '¡LO QUE NO AGREGAS HOY NO ESTARÁ DISPONIBLE DESPUÉS!' }}</p>
      <div class="upm-timer-row">Oferta expira en&nbsp;<span class="upm-timer-count" id="upmCountdown">05:00</span></div>
    </div>

    <!-- Cards de productos -->
