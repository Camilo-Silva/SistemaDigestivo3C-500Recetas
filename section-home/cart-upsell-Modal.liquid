<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  /* ── Upsell Modal Overlay ── */
  .upm-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.55);
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
  }
  .upm-overlay.upm-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Modal ── */
  .upm-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: 460px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,.3);
    transform: scale(.94) translateY(14px);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    overflow: hidden;
  }
  .upm-overlay.upm-open .upm-modal {
    transform: scale(1) translateY(0);
  }

  /* ── Header ── */
  .upm-header {
    padding: 22px 24px 16px;
    text-align: center;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .upm-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: #111;
    line-height: 1.15;
    margin: 0 0 5px;
  }
  .upm-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 17px;
    color: #1a1a2e;
    line-height: 1.25;
    margin: 0 0 12px;
  }
  .upm-timer-row {
    font-family: 'Open Sans', sans-serif;
    font-size: 15px;
    color: #555;
  }
  .upm-timer-count {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: #e03e3e;
    transition: color .3s;
  }
  .upm-timer-count.upm-urgent {
    color: #c0392b;
    animation: upm-pulse .6s ease infinite alternate;
  }
  @keyframes upm-pulse {
    from { opacity: 1; }
    to   { opacity: .55; }
  }

  /* ── Scrollable body ── */
  .upm-body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 14px 16px 10px;
  }

  /* ── Cards ── */
  .upm-card {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 2px solid #e8e8e8;
    border-radius: 12px;
    padding: 10px 12px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: border-color .15s, box-shadow .15s;
    user-select: none;
    -webkit-user-select: none;
  }
  .upm-card:last-child { margin-bottom: 0; }
  .upm-card:hover {
    border-color: #bbb;
    box-shadow: 0 3px 12px rgba(0,0,0,.07);
  }
  .upm-card.upm-selected {
    border-color: #111;
    box-shadow: 0 3px 14px rgba(0,0,0,.1);
  }

  /* ── Card image ── */
  .upm-card-img {
    width: 70px;
    height: 70px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
    background: #f5f5f5;
    display: block;
  }
  .upm-card-img-empty {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    background: #f0f0f0;
    flex-shrink: 0;
  }

  /* ── Card info ── */
  .upm-card-info {
    flex: 1;
    min-width: 0;
  }
  .upm-card-name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #111;
    line-height: 1.3;
    margin-bottom: 5px;
  }
  .upm-card-pricing {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 2px;
  }
  .upm-card-discount {
    background: #e03e3e;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .upm-card-price-old {
    font-family: 'Open Sans', sans-serif;
    font-size: 12px;
    color: #aaa;
    text-decoration: line-through;
  }
  .upm-card-price-new {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 18px;
    color: #111;
    display: block;
    margin-top: 1px;
  }

  /* ── Checkbox ── */
  .upm-checkbox {
    width: 26px;
    height: 26px;
    border: 2px solid #ccc;
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color .15s, background .15s;
    background: #fff;
  }
  .upm-card.upm-selected .upm-checkbox {
    border-color: #111;
    background: #111;
  }
  .upm-checkbox-svg {
    width: 13px;
    height: 11px;
    opacity: 0;
    transition: opacity .15s;
  }
  .upm-card.upm-selected .upm-checkbox-svg { opacity: 1; }

  /* ── Footer ── */
  .upm-footer {
    padding: 12px 18px 18px;
    border-top: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    background: #fff;
  }
  .upm-btn-skip {
    background: none;
    border: none;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    color: #999;
    cursor: pointer;
    padding: 11px 6px;
    flex-shrink: 0;
    transition: color .15s;
    line-height: 1;
  }
  .upm-btn-skip:hover { color: #444; }
  .upm-btn-add {
    flex: 1;
    background: #c4c4c4;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 15px;
    padding: 13px 16px;
    cursor: not-allowed;
    transition: background .2s, opacity .2s;
    text-align: center;
    line-height: 1;
  }
  .upm-btn-add.upm-active {
    background: #2c2c2c;
    cursor: pointer;
  }
  .upm-btn-add.upm-active:hover { background: #111; }
  .upm-btn-add.upm-loading {
    opacity: .7;
    cursor: wait;
  }

  /* ── Savings bar ── */
  .upm-savings-bar {
    padding: 10px 18px;
    background: #fafafa;
    border-top: 1px solid #ebebeb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-shrink: 0;
  }
  .upm-savings-left {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .upm-savings-label {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: #111;
  }
  .upm-savings-sub {
    font-family: 'Open Sans', sans-serif;
    font-size: 13px;
    color: #999;
  }
  .upm-savings-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  .upm-savings-meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .upm-savings-badge {
    background: #e03e3e;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .upm-savings-old {
    font-family: 'Open Sans', sans-serif;
    font-size: 13px;
    color: #aaa;
    text-decoration: line-through;
  }
  .upm-savings-new {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 20px;
    color: #111;
    line-height: 1.1;
  }
</style>

<!-- Overlay del modal -->
<div class="upm-overlay" id="upmOverlay" role="dialog" aria-modal="true" aria-label="Oferta relámpago">
  <div class="upm-modal" id="upmModal">

