    <!-- Footer -->
    <div class="upm-footer">
      <button class="upm-btn-skip" id="upmSkip" type="button">Omitir</button>
      <button class="upm-btn-add" id="upmAddBtn" type="button" disabled>Añadir al carrito</button>
    </div>
    <!-- Barra de estado (debug) -->
    <div id="upmStatus" style="display:none;padding:10px 18px;font-family:'Open Sans',sans-serif;font-size:13px;text-align:center;border-top:1px solid #f0f0f0;"></div>

  </div><!-- /upm-modal -->
</div><!-- /upm-overlay -->

<script>
(function () {
  var CHECKOUT_URL    = '/checkout';
  var MAIN_VARIANT_ID = '{{ section.settings.main_variant_id }}'.trim();
  var TIMER_SECS      = parseInt('{{ section.settings.timer_secs | default: 300 }}', 10);

  var overlay  = document.getElementById('upmOverlay');
  var addBtn   = document.getElementById('upmAddBtn');
  var skipBtn  = document.getElementById('upmSkip');
  var countEl  = document.getElementById('upmCountdown');
  var cards    = Array.from(overlay.querySelectorAll('.upm-card'));

  var remaining     = TIMER_SECS;
  var timerInterval = null;
  var isProcessing  = false;

  /* ── Utilidades ── */
  function pad(n) { return n < 10 ? '0' + n : String(n); }

  function getSelected() {
    return cards.filter(function (c) { return c.classList.contains('upm-selected'); });
  }

  function refreshAddBtn() {
    var selected = getSelected();
    var has = selected.length > 0;
    addBtn.disabled = !has;
    addBtn.classList.toggle('upm-active', has);

    var savingsBar  = document.getElementById('upmSavings');
    var badgeEl     = document.getElementById('upmSavingsBadge');
    var oldEl       = document.getElementById('upmSavingsOld');
    var newEl       = document.getElementById('upmSavingsNew');

    if (!has) { savingsBar.style.display = 'none'; return; }

    var totalNew = 0;
    var totalOld = 0;
    var singleDiscount = selected.length === 1 ? (selected[0].dataset.discount || '').trim() : '';

    selected.forEach(function (card) {
      var pNew = parseInt((card.dataset.priceNew || '').replace(/[^0-9]/g, ''), 10) || 0;
      var pOld = parseInt((card.dataset.priceOld || '').replace(/[^0-9]/g, ''), 10) || 0;
      totalNew += pNew;
      totalOld += pOld > 0 ? pOld : pNew;
    });

    if (singleDiscount) {
      badgeEl.textContent = singleDiscount;
      badgeEl.style.display = 'inline-block';
    } else {
      badgeEl.style.display = 'none';
    }

    if (totalOld > totalNew) {
      oldEl.textContent = '$' + totalOld.toLocaleString('es-AR');
      oldEl.style.display = 'inline';
    } else {
      oldEl.style.display = 'none';
    }

    newEl.textContent = '$' + totalNew.toLocaleString('es-AR');
    savingsBar.style.display = 'flex';
  }

  /* ── Timer ── */
  function updateTimerDisplay() {
    var m = Math.floor(remaining / 60);
    var s = remaining % 60;
    countEl.textContent = pad(m) + ':' + pad(s);
    if (remaining <= 30) countEl.classList.add('upm-urgent');
  }

  function startTimer() {
    remaining = TIMER_SECS;
    updateTimerDisplay();
    timerInterval = setInterval(function () {
      remaining--;
      updateTimerDisplay();
      if (remaining <= 0) {
        clearInterval(timerInterval);
        timerInterval = null;
        hideModal();
        /* Timer agotado: agrega el principal y va al checkout sin upsells */
        goToCheckout([], true);
      }
    }, 1000);
  }

  function stopTimer() {
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  }

  /* ── Abrir / cerrar modal ── */
  function showModal() {
    if (overlay.classList.contains('upm-open')) return;
    cards.forEach(function (c) { c.classList.remove('upm-selected'); });
    refreshAddBtn();
    overlay.classList.add('upm-open');
    document.body.style.overflow = 'hidden';
    startTimer();
  }

  function hideModal() {
    stopTimer();
    overlay.classList.remove('upm-open');
    document.body.style.overflow = '';
  }

  /* ── Ir al checkout: agrega upsells seleccionados y redirige ── */
  function goToCheckout(extraVids, silent) {
    if (isProcessing) return;
    isProcessing = true;

    var statusEl = document.getElementById('upmStatus');

    /* Asegurarse de que el overlay esté visible para mostrar el status */
    if (!silent) overlay.classList.add('upm-open');

    function showStatus(msg, color) {
      if (silent) return;
      statusEl.style.display = 'block';
      statusEl.style.color = color || '#333';
      statusEl.innerHTML = msg;
    }

    /* Filtrar solo IDs válidos — enviar como string, no parseInt */
    var items = extraVids
      .filter(function (vid) { return vid && vid.trim().length > 0; })
      .map(function (vid) { return { id: vid.trim(), quantity: 1 }; });

    /* Siempre incluir el producto principal al inicio */
    if (MAIN_VARIANT_ID) {
      items.unshift({ id: MAIN_VARIANT_ID, quantity: 1 });
    }

    showStatus('Enviando... IDs: [' + items.map(function(i){return i.id;}).join(', ') + ']');

    if (items.length === 0) {
      showStatus('Sin upsells → redirigiendo...', '#888');
      setTimeout(function () { hideModal(); window.location.href = CHECKOUT_URL; }, silent ? 100 : 800);
      return;
    }

    /* Validar que los IDs sean Variant IDs reales antes de intentar agregar */
    showStatus('Validando IDs...');
    Promise.all(items.map(function (item) {
      return fetch('/variants/' + item.id + '.js')
        .then(function (r) { return { id: item.id, ok: r.ok }; })
        .catch(function () { return { id: item.id, ok: false }; });
    })).then(function (results) {
      var invalid = results.filter(function (r) { return !r.ok; });
      if (invalid.length > 0) {
        showStatus(
          '❌ Variant ID incorrecto: <strong>' + invalid.map(function (r) { return r.id; }).join(', ') + '</strong><br>' +
          '<small style="color:#555">Ese es el Product ID, no el Variant ID.<br>' +
          'En Shopify Admin: Productos → [producto] → clic en la variante → URL → número final</small>',
          '#c0392b'
        );
        statusEl.innerHTML += '<br><a href="' + CHECKOUT_URL + '" style="color:#fff;background:#111;padding:6px 14px;border-radius:6px;text-decoration:none;display:inline-block;margin-top:8px;font-size:12px;">Ir al checkout de todas formas →</a>';
        isProcessing = false;
        return;
      }

      /* Verificar qué items ya están en el carrito para no duplicar */
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var inCart = (cart.items || []).map(function (i) { return String(i.variant_id); });
          var newItems = results
            .filter(function (r) { return r.ok; })
            .map(function (r) { return { id: r.id, quantity: 1 }; })
            .filter(function (i) { return inCart.indexOf(i.id) === -1; });

          if (newItems.length === 0) {
            showStatus('✅ Todo ya está en el carrito', 'green');
            setTimeout(function () { hideModal(); window.location.href = CHECKOUT_URL; }, silent ? 100 : 800);
            return;
          }

          showStatus('Agregando al carrito...');
          doAddToCart(newItems);
        })
        .catch(function () {
          /* Si no podemos leer el carrito, agregar de todas formas */
          var newItems = results.filter(function (r) { return r.ok; }).map(function (r) { return { id: r.id, quantity: 1 }; });
          doAddToCart(newItems);
        });
    });

    function doAddToCart(newItems) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: newItems })
      })
      .then(function (res) {
        if (!res.ok) {
          return res.text().then(function (body) {
            var msg = body.length < 400 ? body : body.slice(0, 400);
            try { var j = JSON.parse(body); msg = j.description || j.message || msg; } catch(e) {}
            showStatus('❌ Error ' + res.status + ': ' + msg, '#c0392b');
            statusEl.innerHTML += '<br><a href="' + CHECKOUT_URL + '" style="color:#fff;background:#111;padding:6px 14px;border-radius:6px;text-decoration:none;display:inline-block;margin-top:8px;font-size:12px;">Ir al checkout de todas formas →</a>';
            isProcessing = false;
            throw new Error('shown');
          });
        }
        return res.json();
      })
      .then(function (data) {
        showStatus('✅ ' + (data.items ? data.items.map(function(i){ return i.title; }).join(' + ') : 'Agregado'), 'green');
        setTimeout(function () { hideModal(); window.location.href = CHECKOUT_URL; }, 1200);
      })
      .catch(function (err) {
        if (err.message !== 'shown') {
          showStatus('❌ Error de red: ' + err.message, '#c0392b');
          statusEl.innerHTML += '<br><a href="' + CHECKOUT_URL + '" style="color:#fff;background:#111;padding:6px 14px;border-radius:6px;text-decoration:none;display:inline-block;margin-top:8px;font-size:12px;">Ir al checkout de todas formas →</a>';
          isProcessing = false;
        }
      });
    }
  }

  /* ── Selección de cards ── */
  cards.forEach(function (card) {
    card.addEventListener('click', function () {
      if (isProcessing) return;
      card.classList.toggle('upm-selected');
      refreshAddBtn();
    });
  });

  /* ── Botón "Añadir al carrito" ── */
  addBtn.addEventListener('click', function () {
    if (!addBtn.classList.contains('upm-active') || isProcessing) return;
    stopTimer();
    addBtn.classList.add('upm-loading');
    addBtn.textContent = 'Agregando...';

    var extraVids = getSelected().map(function (c) {
      return (c.dataset.variant || '').trim();
    });

    /* NO llamar hideModal() aquí — goToCheckout lo hace después de mostrar el resultado */
    goToCheckout(extraVids);
  });

  /* ── Botón "Omitir" ── */
  skipBtn.addEventListener('click', function () {
    if (isProcessing) return;
    stopTimer();
    var extraVids = getSelected().map(function (c) {
      return (c.dataset.variant || '').trim();
    });
    goToCheckout(extraVids, true);
  });

  /* ── ESC: solo cierra el modal, no redirige ── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('upm-open')) {
      hideModal();
    }
  });

  /* ── Trigger externo ──
     <a href="#upsell-modal">  o  <button data-upsell-modal>
  ── */
  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('[href="#upsell-modal"], [data-upsell-modal]');
    if (trigger) {
      e.preventDefault();
      showModal();
    }
  });

})();
</script>

