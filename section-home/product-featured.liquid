        {% endif %}
        <div class="clhf-body">
          {% if section.settings.p3_badge != blank %}
            <div class="clhf-badge">{{ section.settings.p3_badge }}</div>
          {% endif %}
          <div class="clhf-title">{{ section.settings.p3_title }}</div>
          {% if section.settings.p3_subtitle != blank %}
            <p class="clhf-subtitle">{{ section.settings.p3_subtitle }}</p>
          {% endif %}
          <div class="clhf-price-row">
            {% if section.settings.p3_price_old != blank %}
              <span class="clhf-price-old">{{ section.settings.p3_price_old }}</span>
            {% endif %}
            <span class="clhf-price-new">{{ section.settings.p3_price_new }}</span>
            {% if section.settings.p3_off_badge != blank %}
              <span class="clhf-off-badge">{{ section.settings.p3_off_badge }}</span>
            {% endif %}
          </div>
          <a href="{{ section.settings.p3_cta_url }}" class="clhf-buy-btn">
