            <img src="{{ section.settings.p4_image | img_url: 'master' }}" alt="{{ section.settings.p4_title }}" class="clhf-img">
          </div>
        {% endif %}
        <div class="clhf-body">
          {% if section.settings.p4_badge != blank %}
            <div class="clhf-badge">{{ section.settings.p4_badge }}</div>
          {% endif %}
          <div class="clhf-title">{{ section.settings.p4_title }}</div>
          {% if section.settings.p4_subtitle != blank %}
