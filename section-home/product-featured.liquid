            <div class="clhf-badge">{{ section.settings.p1_badge }}</div>
          {% endif %}
          <div class="clhf-title">{{ section.settings.p1_title }}</div>
          {% if section.settings.p1_subtitle != blank %}
            <p class="clhf-subtitle">{{ section.settings.p1_subtitle }}</p>
          {% endif %}
          <div class="clhf-price-row">
            {% if section.settings.p1_price_old != blank %}
              <span class="clhf-price-old">{{ section.settings.p1_price_old }}</span>
            {% endif %}
            <span class="clhf-price-new">{{ section.settings.p1_price_new }}</span>
            {% if section.settings.p1_off_badge != blank %}
              <span class="clhf-off-badge">{{ section.settings.p1_off_badge }}</span>
            {% endif %}
          </div>
          <a href="{{ section.settings.p1_cta_url }}" class="clhf-buy-btn">
            <i class="fa-solid fa-bag-shopping"></i> {{ section.settings.p1_cta_text }}
          </a>
          {% if section.settings.trust_text != blank %}
            <p class="clhf-trust"><i class="fa-solid fa-lock"></i> {{ section.settings.trust_text }}</p>
          {% endif %}
        </div>
      </div>

      <!-- ── Card 3 ── -->
      <div class="clhf-card" data-href="{{ section.settings.p3_img_url | default: section.settings.p3_cta_url }}">
        {% if section.settings.p3_image != blank %}
