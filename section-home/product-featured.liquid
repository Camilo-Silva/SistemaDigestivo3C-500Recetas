<style>
  .clhf-section {
    background: {{ section.settings.background_color }};
    padding: 40px 16px 50px;
  }
  .clhf-container {
    max-width: 900px;
    margin: 0 auto;
  }
  .clhf-heading {
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 900;
    font-size: 26px !important;
    color: #111;
    margin-bottom: 24px;
  }

  /* ── Grid 2 columnas ── */
  .clhf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* ── Card featured (fila completa) ── */
  .clhf-card--featured {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: stretch;
  }
  .clhf-card--featured .clhf-img-link {
    width: 42%;
    flex-shrink: 0;
  }
  .clhf-card--featured .clhf-img {
    aspect-ratio: 4 / 3;
    height: 100%;
    object-fit: cover;
  }
  .clhf-card--featured .clhf-body {
    padding: 28px 30px 28px;
    justify-content: center;
  }
  .clhf-card--featured .clhf-title {
    font-size: 22px !important;
  }
  .clhf-card--featured .clhf-price-new {
    font-size: 30px !important;
  }
  .clhf-card--featured .clhf-buy-btn {
    font-size: 17px !important;
    padding: 15px;
  }

  /* ── Card vertical ── */
  .clhf-card {
    background: #fff;
    border: 1px solid #dde0e7;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,.09);
    display: flex;
    flex-direction: column;
    position: relative;
    cursor: pointer;
  }
  .clhf-img-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }
  .clhf-card:hover .clhf-img { opacity: .88; }
  .clhf-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: opacity .15s;
  }
  .clhf-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .clhf-badge {
    display: inline-block;
    background: #ad6639;
    color: #fff;
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 700;
    font-size: 11px !important;
    padding: 3px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: 10px;
    width: fit-content;
  }
  .clhf-title {
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 900;
    font-size: 17px !important;
    color: #111;
    margin-bottom: 7px;
    line-height: 1.3;
  }
  .clhf-subtitle {
    font-family: 'Open Sans', sans-serif !important;
    font-size: 13px !important;
    color: #555;
    margin-bottom: 14px;
    line-height: 1.6;
    flex: 1;
  }
  .clhf-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .clhf-price-old {
    font-size: 13px !important;
    color: #aaa;
    text-decoration: line-through;
    font-family: 'Open Sans', sans-serif !important;
  }
  .clhf-price-new {
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 900;
    font-size: 24px !important;
    color: #ad6639;
  }
  .clhf-off-badge {
    background: rgba(173,102,57,.12);
    color: #7a4520;
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 700;
    font-size: 11px !important;
    padding: 3px 9px;
    border-radius: 5px;
    text-transform: uppercase;
  }
  .clhf-buy-btn {
    display: block;
    background: linear-gradient(180deg, #27ae60, #1e9e4f);
    color: #fff;
    text-align: center;
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 700;
    font-size: 15px !important;
    padding: 13px;
    border-radius: 9px;
    text-decoration: none;
    box-shadow: 0 5px 0 #155a2a, 0 8px 20px rgba(30,158,79,.3);
    transition: all .15s ease;
    position: relative;
    overflow: hidden;
  }
  .clhf-buy-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    animation: clhfShimmer 2.5s infinite;
  }
  @keyframes clhfShimmer { 0%{left:-100%} 100%{left:200%} }
  .clhf-buy-btn:hover { transform: translateY(3px); box-shadow: 0 2px 0 #155a2a, 0 4px 12px rgba(30,158,79,.2); }
  .clhf-trust {
    font-family: 'Open Sans', sans-serif !important;
    font-size: 11px !important;
    color: #999;
    text-align: center;
    margin-top: 9px;
  }

  /* Última card sola en su fila → centrada */
  .clhf-grid > .clhf-card:not(.clhf-card--featured):last-child:nth-child(even) {
    grid-column: 1 / -1;
    max-width: calc(50% - 10px);
    justify-self: center;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    /* El grid mantiene 2 columnas; la card featured ocupa ambas por grid-column: 1/-1 */
    .clhf-card--featured { flex-direction: column; }
    .clhf-card--featured .clhf-img-link { width: 100%; }
    .clhf-card--featured .clhf-img { aspect-ratio: 16 / 9; height: auto; }
    .clhf-card--featured .clhf-title { font-size: 18px !important; }
    .clhf-card--featured .clhf-price-new { font-size: 26px !important; }
    /* En mobile la última card centrada ocupa el ancho completo */
    .clhf-grid > .clhf-card:not(.clhf-card--featured):last-child:nth-child(even) {
      max-width: 100%;
    }
  }
</style>

<section class="clhf-section">
  <div class="clhf-container">

    {% if section.settings.heading != blank %}
      <h2 class="clhf-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="clhf-grid">

      <!-- ── Card 2 — FEATURED (fila completa arriba) ── -->
      <div class="clhf-card clhf-card--featured" data-href="{{ section.settings.p2_img_url | default: section.settings.p2_cta_url }}">
        {% if section.settings.p2_image != blank %}
          <div class="clhf-img-link">
            <img src="{{ section.settings.p2_image | img_url: 'master' }}" alt="{{ section.settings.p2_title }}" class="clhf-img">
          </div>
        {% endif %}
        <div class="clhf-body">
          {% if section.settings.p2_badge != blank %}
            <div class="clhf-badge">{{ section.settings.p2_badge }}</div>
          {% endif %}
          <div class="clhf-title">{{ section.settings.p2_title }}</div>
          {% if section.settings.p2_subtitle != blank %}
            <p class="clhf-subtitle">{{ section.settings.p2_subtitle }}</p>
          {% endif %}
          <div class="clhf-price-row">
            {% if section.settings.p2_price_old != blank %}
              <span class="clhf-price-old">{{ section.settings.p2_price_old }}</span>
            {% endif %}
            <span class="clhf-price-new">{{ section.settings.p2_price_new }}</span>
            {% if section.settings.p2_off_badge != blank %}
              <span class="clhf-off-badge">{{ section.settings.p2_off_badge }}</span>
            {% endif %}
          </div>
          <a href="{{ section.settings.p2_cta_url }}" class="clhf-buy-btn">
            <i class="fa-solid fa-bag-shopping"></i> {{ section.settings.p2_cta_text }}
          </a>
          {% if section.settings.trust_text != blank %}
            <p class="clhf-trust"><i class="fa-solid fa-lock"></i> {{ section.settings.trust_text }}</p>
          {% endif %}
        </div>
      </div>

      <!-- ── Card 1 ── -->
      <div class="clhf-card" data-href="{{ section.settings.p1_img_url | default: section.settings.p1_cta_url }}">
        {% if section.settings.p1_image != blank %}
          <div class="clhf-img-link">
            <img src="{{ section.settings.p1_image | img_url: 'master' }}" alt="{{ section.settings.p1_title }}" class="clhf-img">
