          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  document.querySelectorAll('.clhf-card[data-href]').forEach(function (card) {
    card.addEventListener('click', function (e) {
      var url = card.dataset.href;
      if (!url) return;
      if (e.target.closest('.clhf-buy-btn')) return; // el botón navega solo
      window.location.href = url;
    });
  });
})();
</script>

