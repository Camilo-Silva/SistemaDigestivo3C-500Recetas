          {% endif %}
        </div>
      </div>

      <!-- ── Card 4 ── -->
      <div class="clhf-card" data-href="{{ section.settings.p4_img_url | default: section.settings.p4_cta_url }}">
        {% if section.settings.p4_image != blank %}
